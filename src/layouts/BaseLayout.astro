---
import EstimateModal from '../components/EstimateModal.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = 'https://craftsmandrywallllc.com';
const canonicalUrl = canonical ?? siteUrl + Astro.url.pathname;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Craftsman Drywall LLC",
  "telephone": "(360) 282-2218",
  "url": siteUrl,
  "logo": `${siteUrl}/logo.png`,
  "description": "Licensed, bonded drywall contractor serving Olympia, WA with 30+ years of experience.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Olympia",
    "addressRegion": "WA",
    "postalCode": "98506",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.0379,
    "longitude": -122.9007
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "07:00",
      "closes": "16:00"
    }
  ],
  "priceRange": "$$",
  "areaServed": ["Olympia", "Lacey", "Tumwater", "Yelm", "DuPont", "Steilacoom", "Rainier", "Tenino", "Rochester"],
  "paymentAccepted": "Cash, Check, Venmo",
  "currenciesAccepted": "USD"
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    <meta property="og:site_name" content="Craftsman Drywall LLC" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/craftsman-drywall/favicon.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- LocalBusiness JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="font-sans bg-white text-gray-800 antialiased">
    <slot />
    
    <!-- Global Floating Action Buttons -->
    <div class="fixed bottom-6 right-6 sm:bottom-8 sm:right-8 z-50 flex flex-col items-center gap-3">
      <!-- Free Estimate Button -->
      <button
        data-estimate
        class="bg-blue-brand hover:bg-blue-dark text-white shadow-2xl shadow-blue-brand/30 rounded-full px-5 py-3.5 sm:px-6 sm:py-4 flex items-center justify-center gap-2.5 transition-all duration-300 transform hover:-translate-y-1 focus:outline-none ring-4 ring-white/50 group min-w-[160px] sm:min-w-[200px]"
        aria-label="Request a Free Estimate"
      >
        <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        <span class="font-bold text-sm sm:text-base tracking-wide whitespace-nowrap">Free Estimate</span>
      </button>

      <!-- Review Us Button -->
      <a
        href="https://www.google.com/search?hl=en-US&gl=us&q=Craftsman+Drywall+LLC&ludocid=9374436617341825017&lsig=AB86z5WfKx4IoKyOOyoJBYcwW2Ig#lrd=0x549173bc2c14b065:0x8218b06f8212eff9,3"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-blue-brand hover:bg-blue-dark text-white shadow-2xl shadow-blue-brand/30 rounded-full px-5 py-3.5 sm:px-6 sm:py-4 flex items-center justify-center gap-2.5 transition-all duration-300 transform hover:-translate-y-1 focus:outline-none ring-4 ring-white/50 group min-w-[160px] sm:min-w-[200px]"
      >
        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12.48 10.92v3.28h7.81c-.24 1.84-.85 3.18-1.78 4.15-1.15 1.14-2.98 2.45-6.03 2.45-4.82 0-8.67-3.89-8.67-8.8s3.85-8.8 8.67-8.8c2.62 0 4.6 1.04 6.13 2.5l2.31-2.31C19.34 1.6 16.48 0 12.48 0 5.86 0 .3 5.39.3 12s5.56 12 12.18 12c3.57 0 6.26-1.17 8.37-3.36 2.16-2.16 2.84-5.21 2.84-7.66 0-.76-.05-1.46-.14-2.06h-11.07z"/></svg>
        <span class="font-bold text-sm sm:text-base tracking-wide whitespace-nowrap">Review Us</span>
      </a>
    </div>

    <EstimateModal />
  </body>
</html>
