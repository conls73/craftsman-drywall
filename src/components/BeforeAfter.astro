---
const beforeSrc = '/craftsman-drywall/images/before.jpg';
const afterSrc = '/craftsman-drywall/images/after.jpg';

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`before-after-wrapper flex flex-col gap-6 ${className}`}>
  <!-- Toggle Controls -->
  <div class="absolute top-8 left-1/2 -translate-x-1/2 z-[100]">
    <div class="inline-flex bg-navy/80 backdrop-blur-2xl rounded-2xl p-1.5 border border-white/20 shadow-2xl">
      <button 
        id="btn-slider" 
        class="px-10 py-3 text-xs font-black rounded-xl bg-white text-navy shadow-xl transition-all uppercase tracking-[0.2em]"
      >
        Slider
      </button>
      <button 
        id="btn-side-by-side" 
        class="px-10 py-3 text-xs font-black rounded-xl text-white/70 hover:text-white transition-all uppercase tracking-[0.2em]"
      >
        Side by Side
      </button>
    </div>
  </div>

  <!-- Main Display Area -->
  <div id="display-area" class="before-after-card relative overflow-hidden bg-navy/20 rounded-3xl transition-all duration-700 ease-in-out border border-white/5">
    
    <!-- Slider View (2-Column Mode or Container Mode) -->
    <div id="view-slider" class="relative w-full aspect-[4/5] md:aspect-square overflow-hidden group flex items-center justify-center">
      <img src={afterSrc} class="w-full h-full object-cover select-none pointer-events-none" alt="After" />
      <div id="before-img-container" class="absolute inset-0 w-full h-full overflow-hidden select-none pointer-events-none z-10" style="clip-path: inset(0 50% 0 0);">
          <img src={beforeSrc} class="w-full h-full object-cover" alt="Before" />
      </div>
      
      <!-- Wiping Label -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-[45] pointer-events-none">
          <div class="relative flex items-center justify-center min-w-[160px] h-12 bg-navy/80 backdrop-blur-xl rounded-full border border-white/10 shadow-2xl overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-white text-[10px] font-black uppercase tracking-[0.4em] select-none">After</div>
              <div id="before-label-wipe" class="absolute inset-0 flex items-center justify-center bg-white text-navy text-[10px] font-black uppercase tracking-[0.4em] select-none" style="clip-path: inset(0 50% 0 0);">Before</div>
          </div>
      </div>

      <!-- Handle -->
      <div id="slider-handle" class="absolute top-0 bottom-0 w-1.5 bg-white/40 backdrop-blur-md shadow-[0_0_50px_rgba(0,0,0,0.8)] cursor-ew-resize z-40" style="left: 50%;">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-14 h-14 bg-white rounded-full shadow-[0_0_60px_rgba(37,99,235,0.6)] border-[6px] border-blue-brand flex items-center justify-center transition-all hover:scale-110 active:scale-90">
              <svg class="w-8 h-8 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M8 9l-4 3 4 3m8-6l4 3-4 3" /></svg>
          </div>
      </div>
      <input type="range" id="slider-range-hidden" min="0" max="100" value="50" class="absolute inset-0 w-full h-full opacity-0 cursor-ew-resize z-50" />
    </div>

    <!-- Side by Side View (FULL SCREEN MODE) -->
    <div id="view-side-by-side" class="hidden relative w-full min-h-[60vh] md:min-h-[80vh] bg-navy">
      <div class="grid grid-cols-2 w-full h-full gap-0 bg-navy">
        <div class="relative w-full h-full flex items-center justify-center">
            <div class="absolute top-10 left-10 z-20 bg-white text-navy text-[10px] font-black px-6 py-3 rounded-full uppercase tracking-[0.3em] shadow-2xl border border-gray-200">Before</div>
            <img src={beforeSrc} class="max-w-full max-h-full object-contain" alt="Before" />
        </div>
        <div class="relative w-full h-full flex items-center justify-center">
            <div class="absolute top-10 right-10 z-20 bg-blue-brand text-white text-[10px] font-black px-6 py-3 rounded-full uppercase tracking-[0.3em] shadow-2xl border border-white/10">After</div>
            <img src={afterSrc} class="max-w-full max-h-full object-contain" alt="After" />
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  const initBeforeAfter = () => {
    const rangeInput = document.getElementById('slider-range-hidden') as HTMLInputElement;
    const beforeImgContainer = document.getElementById('before-img-container');
    const beforeLabelWipe = document.getElementById('before-label-wipe');
    const sliderHandle = document.getElementById('slider-handle');
    
    const updateSlider = (val: string) => {
      const percentage = 100 - parseInt(val);
      if (beforeImgContainer) beforeImgContainer.style.clipPath = `inset(0 ${percentage}% 0 0)`;
      if (beforeLabelWipe) beforeLabelWipe.style.clipPath = `inset(0 ${percentage}% 0 0)`;
      if (sliderHandle) sliderHandle.style.left = `${val}%`;
    };

    if (rangeInput) {
      rangeInput.addEventListener('input', (e) => updateSlider((e.target as HTMLInputElement).value));
      updateSlider(rangeInput.value);
    }

    const btnSlider = document.getElementById('btn-slider');
    const btnSideBySide = document.getElementById('btn-side-by-side');
    const viewSlider = document.getElementById('view-slider');
    const viewSideBySide = document.getElementById('view-side-by-side');
    const displayArea = document.getElementById('display-area');

    const setMode = (mode: 'slider' | 'side-by-side') => {
      if (!btnSlider || !btnSideBySide || !viewSlider || !viewSideBySide || !displayArea) return;

      if (mode === 'slider') {
        viewSlider.classList.remove('hidden');
        viewSideBySide.classList.add('hidden');
        
        btnSlider.classList.add('bg-white', 'text-navy');
        btnSlider.classList.remove('text-white/70', 'hover:text-white');
        btnSideBySide.classList.remove('bg-white', 'text-navy');
        btnSideBySide.classList.add('text-white/70', 'hover:text-white');
        
        // Dispatch event to parent to restore layout
        window.dispatchEvent(new CustomEvent('hero-mode-change', { detail: { mode: 'slider' } }));
      } else {
        viewSlider.classList.add('hidden');
        viewSideBySide.classList.remove('hidden');
        
        btnSideBySide.classList.add('bg-white', 'text-navy');
        btnSideBySide.classList.remove('text-white/70', 'hover:text-white');
        btnSlider.classList.remove('bg-white', 'text-navy');
        btnSlider.classList.add('text-white/70', 'hover:text-white');

        // Dispatch event to parent to expand layout
        window.dispatchEvent(new CustomEvent('hero-mode-change', { detail: { mode: 'side-by-side' } }));
      }
    };

    btnSlider?.addEventListener('click', () => setMode('slider'));
    btnSideBySide?.addEventListener('click', () => setMode('side-by-side'));
  };

  document.addEventListener('DOMContentLoaded', initBeforeAfter);
  document.addEventListener('astro:page-load', initBeforeAfter);
</script>
