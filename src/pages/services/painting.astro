---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';
---

<BaseLayout
  title="Interior Painting across Washington | Craftsman Drywall LLC"
  description="Clean interior painting for walls, ceilings, trim, doors, cabinets, and finished living spaces across Washington."
>
  <Header />

  <section class="bg-navy py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center reveal">
      <a href="/craftsman-drywall/services" class="inline-flex items-center gap-1.5 text-white/50 text-sm hover:text-white mb-8 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Services
      </a>
      <p class="text-blue-brand font-semibold text-sm uppercase tracking-widest mb-4">Service</p>
      <h1 class="text-5xl sm:text-7xl font-extrabold text-white mb-6">Interior Painting</h1>
      <p class="text-white/70 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">Clean interior painting for walls, ceilings, trim, doors, cabinets, and finished living spaces across Washington.</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-8 reveal reveal-delay-1">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Clean Interior Painting That Makes a Room Feel Finished</h2>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              <p>A great interior paint job starts with careful prep. We protect your floors, cover surrounding surfaces, patch small imperfections, sand where needed, and make sure every surface is ready before paint is applied.</p>
              <p>From walls and ceilings to trim, doors, cabinets, and detailed finish work, Craftsman Drywall LLC provides clean lines, smooth coverage, and professional results that help your home or business feel refreshed.</p>
            </div>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-5">Painting Services</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { 
                  title: 'Interior Painting', 
                  desc: 'Walls, ceilings, trim, and doors — clean lines and even coverage throughout.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 4h8a2 2 0 012 2v14a2 2 0 01-2 2H8a2 2 0 01-2-2V6a2 2 0 012-2zm6 10v.01" />`
                },
                { 
                  title: 'Cabinet & Door Painting', 
                  desc: 'Refresh your kitchen, bathrooms, and interior doors with a smooth, durable finish.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a2 2 0 012-2h12a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V5z M12 3v18 M10 11v2 M14 11v2" />`
                },
                { 
                  title: 'Primer & Prep', 
                  desc: 'Full surface preparation, priming, and caulking before any color goes on.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />`
                },
                { 
                  title: 'New Drywall Painting', 
                  desc: 'Painting fresh drywall after installation — we know the right primers to use.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.143-7.714L1.143 12l7.714-2.143L11 3z" />`
                },
                { 
                  title: 'Trim & Detail Work', 
                  desc: 'Baseboards, crown molding, window trim — clean tape lines and careful brush work.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V5z" />`
                },
                { 
                  title: 'Color Consultation', 
                  desc: 'We can help you pick colors that work well with your space and lighting.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />`
                },
              ].map((item, index) => (
                <div class={`bg-gray-50 rounded-xl p-6 border border-gray-100 flex gap-4 service-card reveal ${index > 0 ? "reveal-delay-" + ((index % 3) + 1) : ""}`}>
                  <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <Fragment set:html={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 mb-1">{item.title}</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="space-y-5 reveal reveal-delay-2">
          <div class="bg-navy text-white rounded-2xl p-7">
            <h3 class="font-bold text-lg mb-4">Ready for a Fresh Look?</h3>
            <p class="text-white/70 text-sm mb-5">Free painting estimates for residential and commercial clients.</p>
            <a href="/craftsman-drywall/contact" data-estimate class="cta-button block bg-blue-brand hover:bg-blue-dark text-white font-bold text-center py-3 px-5 rounded-xl">Get a Free Estimate</a>
            <a href="tel:3602822218" class="cta-button block mt-3 border border-white/20 text-white text-center py-3 px-5 rounded-xl text-sm hover:bg-white/10">(360) 282-2218</a>
          </div>
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-3">Service Details</h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Residential & commercial</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Free estimates</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Licensed & insured</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Mon–Fri, 7am to 5pm</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Senior & military discount</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABanner heading="Ready for a Fresh Coat?" subtext="Call us or request a free painting estimate. We serve across Washington." />
  <Footer />
</BaseLayout>
