---
const beforeSrc = '/craftsman-drywall/images/before.jpg';
const afterSrc = '/craftsman-drywall/images/after.jpg';

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`before-after-component w-full relative overflow-hidden bg-navy group ${className}`}>
  <!-- Dynamic Background (Blurred) -->
  <div class="absolute inset-0 z-0 opacity-40 blur-3xl scale-110">
    <img src={afterSrc} class="w-full h-full object-cover" alt="" />
  </div>

  <!-- Toggle Controls -->
  <div class="absolute top-8 left-1/2 -translate-x-1/2 z-50">
    <div class="inline-flex bg-white/10 backdrop-blur-2xl rounded-2xl p-1.5 border border-white/20 shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
      <button 
        id="btn-slider" 
        class="px-8 py-3 text-[10px] font-black rounded-xl bg-white text-navy shadow-xl transition-all uppercase tracking-[0.2em]"
      >
        Slider
      </button>
      <button 
        id="btn-side-by-side" 
        class="px-8 py-3 text-[10px] font-black rounded-xl text-white/70 hover:text-white transition-all uppercase tracking-[0.2em]"
      >
        Side by Side
      </button>
    </div>
  </div>

  <!-- Slider View (NO CROP) -->
  <div id="view-slider" class="relative w-full h-[60vh] md:h-[80vh] lg:h-[90vh] overflow-hidden group flex items-center justify-center">
    <div class="relative w-full h-full max-w-7xl mx-auto flex items-center justify-center">
        <!-- Base image (After) -->
        <img 
            src={afterSrc} 
            class="max-w-full max-h-full object-contain select-none pointer-events-none transition-transform duration-1000" 
            alt="After Remodel" 
        />
        <div class="absolute bottom-8 right-8 md:right-20 bg-blue-brand text-white text-[10px] font-black px-6 py-3 rounded-full shadow-2xl z-[45] border border-white/20 uppercase tracking-[0.3em]">After</div>

        <!-- Overlay image (Before) -->
        <div 
        id="before-img-container" 
        class="absolute inset-0 w-full h-full overflow-hidden select-none pointer-events-none z-10 flex items-center justify-center"
        style="clip-path: inset(0 50% 0 0);"
        >
        <img 
            src={beforeSrc} 
            class="max-w-full max-h-full object-contain" 
            alt="Before Remodel" 
        />
        <div class="absolute bottom-8 left-8 md:left-20 bg-white text-navy text-[10px] font-black px-6 py-3 rounded-full shadow-2xl z-[45] border border-gray-200 uppercase tracking-[0.3em]">Before</div>
        </div>
        
        <!-- Vertical Drag Handle (Now matches the image height if possible, or just stays full) -->
        <div 
            id="slider-handle" 
            class="absolute top-0 bottom-0 w-1 bg-white/40 backdrop-blur-md shadow-[0_0_50px_rgba(0,0,0,0.8)] cursor-ew-resize z-40"
            style="left: 50%;"
        >
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-14 h-14 bg-white rounded-full shadow-[0_0_60px_rgba(37,99,235,0.6)] border-[5px] border-blue-brand flex items-center justify-center transition-all hover:scale-110 active:scale-90">
            <svg class="w-7 h-7 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M8 9l-4 3 4 3m8-6l4 3-4 3" />
            </svg>
        </div>
        </div>
    </div>

    <!-- Invisible range input for interaction -->
    <input 
        type="range" 
        id="slider-range-hidden" 
        min="0" 
        max="100" 
        value="50" 
        class="absolute inset-0 w-full h-full opacity-0 cursor-ew-resize z-50"
    />
  </div>

  <!-- Side by Side View (WHOLE SCREEN, NO CROP) -->
  <div id="view-side-by-side" class="hidden h-[80vh] md:h-[100vh] lg:h-[100vh] bg-navy relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 w-full h-full">
        <div class="relative w-full h-full flex items-center justify-center overflow-hidden bg-navy/20 p-4">
        <img src={beforeSrc} class="max-w-full max-h-full object-contain block shadow-2xl rounded-sm" alt="Before Remodel" />
        <div class="absolute bottom-12 left-12 bg-white text-navy text-[10px] font-black px-6 py-3 rounded-full shadow-2xl z-[45] border border-gray-200 uppercase tracking-[0.3em]">Before</div>
        </div>
        <div class="relative w-full h-full flex items-center justify-center overflow-hidden bg-navy/20 p-4">
        <img src={afterSrc} class="max-w-full max-h-full object-contain block shadow-2xl rounded-sm" alt="After Remodel" />
        <div class="absolute bottom-12 right-12 bg-blue-brand text-white text-[10px] font-black px-6 py-3 rounded-full shadow-2xl z-[45] border border-white/20 uppercase tracking-[0.3em]">After</div>
        </div>
    </div>
  </div>

  <!-- Slot for Content Overlay - Positioned only for Slider view maybe? No, let's keep it global but adjustable -->
  <div id="hero-content-slot" class="absolute inset-0 pointer-events-none z-30 flex items-center bg-gradient-to-r from-navy/90 via-navy/40 to-transparent transition-opacity duration-500">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 w-full">
        <slot />
    </div>
  </div>
</div>

<script>
  const initBeforeAfter = () => {
    const rangeInput = document.getElementById('slider-range-hidden') as HTMLInputElement;
    const beforeImgContainer = document.getElementById('before-img-container');
    const sliderHandle = document.getElementById('slider-handle');
    const heroContent = document.getElementById('hero-content-slot');
    
    const updateSlider = (val: string) => {
      if (beforeImgContainer) {
        beforeImgContainer.style.clipPath = `inset(0 ${100 - parseInt(val)}% 0 0)`;
      }
      if (sliderHandle) {
        sliderHandle.style.left = `${val}%`;
      }
    };

    if (rangeInput) {
      rangeInput.addEventListener('input', (e) => {
        updateSlider((e.target as HTMLInputElement).value);
      });
      updateSlider(rangeInput.value);
    }

    const btnSlider = document.getElementById('btn-slider');
    const btnSideBySide = document.getElementById('btn-side-by-side');
    const viewSlider = document.getElementById('view-slider');
    const viewSideBySide = document.getElementById('view-side-by-side');

    if (btnSlider && btnSideBySide && viewSlider && viewSideBySide) {
      btnSlider.addEventListener('click', () => {
        viewSlider.classList.remove('hidden');
        viewSideBySide.classList.add('hidden');
        if (heroContent) heroContent.style.opacity = '1';

        btnSlider.classList.add('bg-white', 'text-navy');
        btnSlider.classList.remove('text-white/70', 'hover:text-white');
        
        btnSideBySide.classList.remove('bg-white', 'text-navy');
        btnSideBySide.classList.add('text-white/70', 'hover:text-white');
      });

      btnSideBySide.addEventListener('click', () => {
        viewSlider.classList.add('hidden');
        viewSideBySide.classList.remove('hidden');
        // Hide hero text overlay in side-by-side mode to show the images "whole screen"
        if (heroContent) heroContent.style.opacity = '0';

        btnSideBySide.classList.add('bg-white', 'text-navy');
        btnSideBySide.classList.remove('text-white/70', 'hover:text-white');
        
        btnSlider.classList.remove('bg-white', 'text-navy');
        btnSlider.classList.add('text-white/70', 'hover:text-white');
      });
    }
  };

  document.addEventListener('DOMContentLoaded', initBeforeAfter);
  document.addEventListener('astro:page-load', initBeforeAfter);
</script>
