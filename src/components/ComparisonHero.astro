---
const beforeSrc = '/craftsman-drywall/images/before.jpg';
const afterSrc = '/craftsman-drywall/images/after.jpg';

const slideshowImages = Array.from(
  { length: 36 },
  (_, i) => `/craftsman-drywall/images/gallery/photo-${i + 1}.jpg`
);
---

<div id="master-hero-root" class="hero-state-side-by-side relative w-full overflow-hidden bg-navy">

  <!-- Hero Content Area (Desktop) -->
  <div class="relative w-full min-h-[100vh] min-[641px]:min-h-[950px] min-[641px]:flex hidden items-center pt-20">
    
    <!-- FULL HEADER SIDE-BY-SIDE MODE (Background) -->
    <div id="bg-side-by-side" class="absolute inset-0 flex transition-opacity duration-700">
      <div class="relative w-1/2 h-full overflow-hidden">
        <img src={beforeSrc} class="absolute inset-0 w-full h-full object-cover brightness-[1.05] contrast-[1.05]" alt="Before" />
        <div class="absolute top-8 left-1/2 -translate-x-1/2 z-20 text-white text-3xl font-black uppercase tracking-[0.2em] reveal reveal-slow reveal-delay-2" style="text-shadow: -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000, 2px 2px 0 #000, 0 4px 6px rgba(0,0,0,0.5);">Before</div>
      </div>
      <div class="relative w-1/2 h-full overflow-hidden">
        <img src={afterSrc} class="absolute inset-0 w-full h-full object-cover brightness-[1.05] contrast-[1.05]" alt="After" />
        <div class="absolute top-8 left-1/2 -translate-x-1/2 z-20 text-white text-3xl font-black uppercase tracking-[0.2em] reveal reveal-delay-3" style="text-shadow: -2px -2px 0 #000, 2px -2px 0 #000, -2px 2px 0 #000, 2px 2px 0 #000, 0 4px 6px rgba(0,0,0,0.5);">After</div>
      </div>
      <div class="absolute top-0 bottom-0 left-1/2 w-px bg-white/20 z-10"></div>
    </div>

    <!-- Hero Copy -->
    <div id="hero-copy-wrapper" class="absolute inset-0 flex items-center justify-center z-[60] px-6 sm:px-10 lg:px-16 pointer-events-none">
      <div id="hero-copy-card" class="desktop-hero-card reveal max-w-3xl pointer-events-auto mt-12 bg-navy/65 backdrop-blur-2xl p-8 sm:p-12 rounded-[2.5rem] border border-white/10 shadow-2xl">
        <h1 class="hero-title text-3xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-[1.15] mb-8">
          <span class="hero-title-white block">Washington’s Trusted</span>
          <span class="hero-title-blue text-blue-brand block">Drywall and Painting Experts</span>
        </h1>
        <p class="desktop-hero-body text-lg sm:text-xl text-white/80 mb-12 leading-relaxed font-medium max-w-2xl">
          30+ years experience installing and finishing. Licensed, bonded and insured.
        </p>
        <div class="desktop-hero-buttons hero-buttons flex flex-col sm:flex-row gap-6 reveal reveal-delay-1">
          <a href="/craftsman-drywall/contact#contact-form" data-estimate-trigger class="cta-button hero-estimate-button free-estimate-button flex-1 bg-blue-brand hover:bg-blue-dark text-white font-bold px-10 py-5 rounded-xl text-lg shadow-xl shadow-blue-brand/20 text-center transition-all duration-300">
            Get a Free Estimate
          </a>
          <a href="tel:3602822218" class="cta-button hero-phone-button flex-1 bg-white/10 hover:bg-white/20 text-white border border-white/20 font-semibold px-10 py-5 rounded-xl text-lg backdrop-blur-md text-center transition-all duration-300">
            (360) 282-2218
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Stacked Layout -->
  <div class="mobile-hero-shell hidden max-[640px]:flex relative min-h-[85vh] items-center justify-center px-4 py-16 overflow-hidden">
    <!-- Mobile Slideshow Background -->
    <div class="absolute inset-0 z-0">
      <div id="mobile-slideshow" class="absolute inset-0 w-full h-full">
        {slideshowImages.map((src, i) => (
          <img 
            src={src} 
            alt="" 
            class={`slideshow-image absolute inset-0 w-full h-full object-cover ${i === 0 ? 'is-active opacity-100' : 'opacity-0'}`} 
            style="object-position: center;"
          />
        ))}
      </div>
      <!-- Dark Overlay -->
      <div class="absolute inset-0 bg-navy/60 z-10"></div>
    </div>

    <!-- Header Card -->
    <div class="mobile-hero-card relative z-20 w-full max-w-lg rounded-[1.5rem] border reveal">
      <p class="mobile-hero-label text-white font-bold">
        Washington’s Trusted<br /><span class="text-blue-brand">Drywall & Painting Experts</span>
      </p>
      <div class="mobile-hero-actions flex items-center gap-3 reveal reveal-delay-1">
        <a href="/craftsman-drywall/contact" data-estimate-trigger class="cta-button mobile-estimate-button free-estimate-button bg-blue-brand text-white font-bold px-8 py-5 rounded-2xl text-lg text-center shadow-lg shadow-blue-brand/20 hover:bg-blue-dark">
          Free Estimate
        </a>
        <a href="tel:3602822218" class="cta-button mobile-phone-button bg-white/10 border border-white/20 text-white font-semibold rounded-2xl text-center hover:bg-white/20 backdrop-blur-md" aria-label="Call Craftsman Drywall">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106a1.125 1.125 0 00-1.173.417l-.97 1.293a1.125 1.125 0 01-1.21.38 12.035 12.035 0 01-7.143-7.143 1.125 1.125 0 01.38-1.21l1.293-.97c.36-.27.527-.727.417-1.173L6.963 3.102A1.125 1.125 0 005.872 2.25H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </a>
      </div>
    </div>
  </div>

</div>



<script>
  function shuffleArray(array) {
    const shuffled = [...array];

    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }

    return shuffled;
  }

  function initMobileSlideshow() {
    const slideshow = document.getElementById('mobile-slideshow');
    if (!slideshow || slideshow.dataset.initialized === 'true') return;

    const images = Array.from(slideshow.querySelectorAll('img'));
    if (images.length < 2) return;

    slideshow.dataset.initialized = 'true';
    let currentImage = null;
    let shuffledSlides = shuffleArray(images);
    let currentSlideIndex = 0;

    function reshuffleSlides() {
      const previousImage = currentImage;
      shuffledSlides = shuffleArray(images);

      if (previousImage && shuffledSlides[0] === previousImage && shuffledSlides.length > 1) {
        [shuffledSlides[0], shuffledSlides[1]] = [shuffledSlides[1], shuffledSlides[0]];
      }

      currentSlideIndex = 0;
    }

    function showNextSlide() {
      if (currentSlideIndex >= shuffledSlides.length) {
        reshuffleSlides();
      }

      const nextImage = shuffledSlides[currentSlideIndex];
      currentSlideIndex += 1;

      currentImage?.classList.remove('is-active', 'opacity-100');
      currentImage?.classList.add('is-previous');
      currentImage?.classList.add('opacity-0');

      nextImage.classList.remove('opacity-0');
      nextImage.classList.remove('is-previous');
      nextImage.classList.add('is-active', 'opacity-100');

      if (currentImage) {
        window.setTimeout(() => {
          currentImage?.classList.remove('is-previous');
        }, 1000);
      }

      currentImage = nextImage;
    }

    images.forEach((image) => {
      image.classList.remove('is-active', 'is-previous', 'opacity-100');
      image.classList.add('opacity-0');
    });

    showNextSlide();
    setInterval(showNextSlide, 5000);
  }

  document.addEventListener('DOMContentLoaded', initMobileSlideshow);
  document.addEventListener('astro:page-load', initMobileSlideshow);
</script>
