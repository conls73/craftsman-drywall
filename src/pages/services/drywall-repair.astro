---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';
---

<BaseLayout
  title="Drywall Repair & Hole Patching in Washington | Craftsman Drywall LLC"
  description="Expert drywall repair, hole patching, and texture matching by Craftsman Drywall LLC. Serving Washington. Seamless results. Free estimates."
>
  <Header />

  <section class="bg-navy py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center">
      <a href="/craftsman-drywall/services" class="inline-flex items-center gap-1.5 text-white/50 text-sm hover:text-white mb-8 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Services
      </a>
      <p class="text-blue-brand font-semibold text-sm uppercase tracking-widest mb-4">Service</p>
      <h1 class="text-5xl sm:text-7xl font-extrabold text-white mb-6">Drywall Repair</h1>
      <p class="text-white/70 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">Expert patching and repair for holes, cracks, water damage, and texture matching across Washington.</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Expert Drywall Repair</h2>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              <p>Drywall damage happens. Doorknobs leave holes, pipes leak, settling causes cracks — it's all fixable. With 30+ years of experience, Craftsman Drywall LLC can repair drywall damage of any size and blend it seamlessly with your existing walls.</p>
              <p>Our signature skill is <strong>texture matching</strong>. Whether your home has orange peel, knock-down, skip trowel, or a smooth finish, we replicate it precisely so you'll never know the repair happened.</p>
            </div>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-5">Repair Services</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { 
                  title: 'Hole Repair', 
                  desc: 'Small nail holes to large door-knob sized damage — all repaired and finished.',
                  icon: `<circle cx="12" cy="12" r="3" fill="currentColor"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`
                },
                { 
                  title: 'Crack Repair', 
                  desc: 'Hairline cracks to large stress fractures, properly stabilized and finished.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4h16v16H4V4zm9 0l-2 4 2 4-2 4 2 4" />`
                },
                { 
                  title: 'Water Damage', 
                  desc: 'Damaged drywall from leaks replaced with moisture-resistant material.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21.5c-4.142 0-7.5-3.358-7.5-7.5 0-3.75 4.5-9 7.5-11.5 3 2.5 7.5 7.75 7.5 11.5 0 4.142-3.358 7.5-7.5 7.5z" />` 
                },
                { 
                  title: 'Texture Matching', 
                  desc: 'We match orange peel, knock-down, skip trowel, popcorn, and smooth finishes.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM9 12h6M12 9v6" />`
                },
                { 
                  title: 'Nail Pops', 
                  desc: 'Popped nails and screws properly fixed, not just covered over.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10M12 3v18m0-18L9 6m3-3l3 3" />`
                },
                { 
                  title: 'Corner Bead Repair', 
                  desc: 'Damaged corner beads replaced and blended to match surrounding walls.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 12V3m0 9l8 4.5M12 12l-8 4.5" />`
                },
              ].map(item => (
                <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 flex gap-4">
                  <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <Fragment set:html={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 mb-1">{item.title}</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-5">
          <div class="bg-navy text-white rounded-2xl p-7">
            <h3 class="font-bold text-lg mb-4">Get It Fixed Today</h3>
            <p class="text-white/70 text-sm mb-5">Free estimates on all repair work. Same-day response.</p>
            <a href="/craftsman-drywall/contact" data-estimate class="block bg-blue-brand hover:bg-blue-dark text-white font-bold text-center py-3 px-5 rounded-xl transition-colors">Request Estimate</a>
            <a href="tel:3602822218" class="block mt-3 border border-white/20 text-white text-center py-3 px-5 rounded-xl text-sm hover:bg-white/10 transition-colors">(360) 282-2218</a>
          </div>
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-3">Service Details</h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Residential & commercial</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Free estimates</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Licensed & insured</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Mon–Fri, 7am to 5pm</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Senior & military discount</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABanner heading="Got Drywall Damage?" subtext="We'll fix it fast and make it look brand new. Free estimate, no obligation." />
  <Footer />
</BaseLayout>
