---
import EstimateModal from '../components/EstimateModal.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = 'https://craftsmandrywallllc.com';
const canonicalUrl = canonical ?? siteUrl + Astro.url.pathname;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Craftsman Drywall LLC",
  "telephone": "(360) 282-2218",
  "url": siteUrl,
  "logo": `${siteUrl}/logo.png`,
  "description": "Licensed, bonded drywall contractor serving Olympia, WA with 30+ years of experience.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Olympia",
    "addressRegion": "WA",
    "postalCode": "98506",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.0379,
    "longitude": -122.9007
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "07:00",
      "closes": "16:00"
    }
  ],
  "priceRange": "$$",
  "areaServed": ["Olympia", "Lacey", "Tumwater", "Yelm", "DuPont", "Steilacoom", "Rainier", "Tenino", "Rochester"],
  "paymentAccepted": "Cash, Check, Venmo",
  "currenciesAccepted": "USD"
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    <meta property="og:site_name" content="Craftsman Drywall LLC" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/craftsman-drywall/favicon.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- LocalBusiness JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="font-sans bg-white text-gray-800 antialiased">
    <slot />
    
    <!-- Global Floating Action Button -->
    <button
      data-estimate
      class="fixed bottom-6 right-6 sm:bottom-8 sm:right-8 z-50 bg-blue-brand hover:bg-blue-dark text-white shadow-2xl shadow-blue-brand/30 rounded-full px-5 py-3.5 sm:px-6 sm:py-4 flex items-center gap-2.5 transition-all duration-300 transform hover:-translate-y-1 focus:outline-none ring-4 ring-white/50 group"
      aria-label="Request a Free Estimate"
    >
      <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
      </svg>
      <span class="font-bold text-sm sm:text-base tracking-wide">Free Estimate</span>
    </button>

    <EstimateModal />
  </body>
</html>
