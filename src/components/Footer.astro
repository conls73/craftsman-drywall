---
const services = [
  { href: '/craftsman-drywall/services/drywall-installation', label: 'Drywall Installation' },
  { href: '/craftsman-drywall/services/drywall-repair', label: 'Drywall Repair' },
  { href: '/craftsman-drywall/services/remodeling', label: 'Remodeling' },
  { href: '/craftsman-drywall/services/painting', label: 'Painting' },
];

const links = [
  { href: '/craftsman-drywall/about', label: 'About Us' },
  { href: '/craftsman-drywall/gallery', label: 'Gallery' },
  { href: '/craftsman-drywall/contact', label: 'Contact' },
];
---

<footer class="bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <img src="/craftsman-drywall/logo.png" alt="Craftsman Drywall LLC" class="h-12 mb-4" />
        <p class="text-white/60 text-sm leading-relaxed">
          Serving Olympia, WA and surrounding communities with quality drywall services since 1994.
        </p>
        <div class="mt-4 flex gap-2">
          <span class="text-xs bg-white/10 text-white/70 px-2 py-1 rounded">Licensed</span>
          <span class="text-xs bg-white/10 text-white/70 px-2 py-1 rounded">Bonded</span>
          <span class="text-xs bg-white/10 text-white/70 px-2 py-1 rounded">Insured</span>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-2">
          {services.map(s => (
            <li>
              <a href={s.href} class="text-white/60 text-sm hover:text-blue-brand transition-colors">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-2">
          {links.map(l => (
            <li>
              <a href={l.href} class="text-white/60 text-sm hover:text-blue-brand transition-colors">
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">Contact</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-brand mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:3602822218" class="text-white/70 text-sm hover:text-white">(360) 282-2218</a>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-brand mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/70 text-sm">Olympia, WA 98506</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-brand mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-white/70 text-sm">Mon–Fri: 7:00am – 4:00pm</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-blue-brand mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
            </svg>
            <span class="text-white/70 text-sm">Cash · Check · Venmo</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-6">
      <p class="text-white/40 text-sm text-center md:text-left">
        &copy; {new Date().getFullYear()} Craftsman Drywall LLC. All rights reserved. Olympia, WA.
      </p>

      <div class="flex items-center gap-4">
        <a href="https://www.facebook.com/p/Craftsman-Drywall-LLC-61565516558153/" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:text-white transition-colors flex items-center justify-center w-8 h-8" aria-label="Facebook">
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
        </a>
        <a href="https://www.google.com/maps/place/Craftsman+Drywall+LLC/data=!4m2!3m1!1s0x0:0x8218b06f8212eff9?sa=X&ved=1t:2428&ictx=111" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:text-white transition-colors flex items-center justify-center w-8 h-8" aria-label="Google Maps">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12.48 10.92v3.28h7.81c-.24 1.84-.85 3.18-1.78 4.15-1.15 1.14-2.98 2.45-6.03 2.45-4.82 0-8.67-3.89-8.67-8.8s3.85-8.8 8.67-8.8c2.62 0 4.6 1.04 6.13 2.5l2.31-2.31C19.34 1.6 16.48 0 12.48 0 5.86 0 .3 5.39.3 12s5.56 12 12.18 12c3.57 0 6.26-1.17 8.37-3.36 2.16-2.16 2.84-5.21 2.84-7.66 0-.76-.05-1.46-.14-2.06h-11.07z"/></svg>
        </a>
        <a href="https://www.angi.com/companylist/us/wa/olympia/craftsman-drywall-llc-reviews-10583896.htm" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:text-white transition-colors flex items-center justify-center w-8 h-8" aria-label="Angi">
          <div class="w-6 h-6 bg-current" style="mask-image: url('/craftsman-drywall/images/angi-logo.png'); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url('/craftsman-drywall/images/angi-logo.png'); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;"></div>
        </a>
      </div>

      <p class="text-white/40 text-sm text-center md:text-right">
        10% Senior & Military Discount
      </p>
    </div>
  </div>
</footer>
