---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CTABanner from "../../components/CTABanner.astro";
---

<BaseLayout
  title="Remodeling Services across Washington — Drywall & Finishing | Craftsman Drywall LLC"
  description="Residential and commercial remodeling drywall services by Craftsman Drywall LLC. Basement finishing, kitchen & bath remodels, room additions. Washington."
>
  <Header />

  <section class="bg-navy py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center">
      <a href="/craftsman-drywall/services" class="inline-flex items-center gap-1.5 text-white/50 text-sm hover:text-white mb-8 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        All Services
      </a>
      <p class="text-blue-brand font-semibold text-sm uppercase tracking-widest mb-4">Service</p>
      <h1 class="text-5xl sm:text-7xl font-extrabold text-white mb-6">Remodeling</h1>
      <p class="text-white/70 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">Full-service residential and commercial remodeling, from basement finishing to complete room updates.</p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">
              Your Remodel, Done Right
            </h2>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              <p>
                Remodeling projects demand precision. When you're transforming a
                basement, updating a kitchen, or adding a new room, the drywall
                work needs to integrate perfectly with the existing structure
                and be finished flawlessly.
              </p>
              <p>
                Craftsman Drywall LLC works alongside contractors, designers,
                and homeowners to deliver remodeling drywall that's on time, on
                budget, and built to last.
              </p>
            </div>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-5">
              Remodeling Projects We Handle
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {
                [
                  {
                    title: "Basement Finishing",
                    desc: "Turn unfinished space into livable, beautiful rooms with professional drywall installation.",
                    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 19h4v-4h4v-4h4v-4h4V3" />`,
                  },
                  {
                    title: "Kitchen Remodels",
                    desc: "Moisture and fire-resistant options for kitchens and the walls around cooking areas.",
                    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12H3m0 0l2 8h14l2-8M3 12l2-4h14l2 4M12 4v4m-3-4h6" />`,
                  },
                  {
                    title: "Bathroom Updates",
                    desc: "Cement board and moisture-resistant drywall for wet areas and shower surrounds.",
                    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 4a2 2 0 114 0M7 6h10l-1 7H8l-1-7zM5 15h14M7 15c0 4 2 6 5 6s5-2 5-6M10 21l-1 4h6l-1-4" />`,
                  },
                  {
                    title: "Room Additions",
                    desc: "Seamlessly integrate new additions with your existing home interior.",
                    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />`,
                  },
                  {
                    title: "Commercial Tenant Improvements",
                    desc: "Fast, professional drywall for office buildouts and retail spaces.",
                    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m4 0h1m-5 4h1m4 0h1m-5 4h1m4 0h1" />`,
                  },
                  {
                    title: "Garage Conversions",
                    desc: "Fire-rated drywall installation for garages being converted to living space.",
                    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v20c0 4.418 7.163 8 16 8s16-3.582 16-8V14c0-4.418-7.163-8-16-8S8 9.582 8 14z" />`,
                  },
                ].map((item) => (
                  <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 flex gap-4">
                    <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center flex-shrink-0">
                      <svg
                        class="w-6 h-6 text-blue-brand"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <Fragment set:html={item.icon} />
                      </svg>
                    </div>
                    <div>
                      <h3 class="font-semibold text-gray-900 mb-1">
                        {item.title}
                      </h3>
                      <p class="text-gray-500 text-sm leading-relaxed">
                        {item.desc}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div class="space-y-5">
          <div class="bg-navy text-white rounded-2xl p-7">
            <h3 class="font-bold text-lg mb-4">Planning a Remodel?</h3>
            <p class="text-white/70 text-sm mb-5">
              Let us quote the drywall portion of your project. Free estimates,
              fast turnaround.
            </p>
            <a
              href="/craftsman-drywall/contact"
              data-estimate
              class="block bg-blue-brand hover:bg-blue-dark text-white font-bold text-center py-3 px-5 rounded-xl transition-colors"
              >Get a Free Estimate</a
            >
            <a
              href="tel:3602822218"
              class="block mt-3 border border-white/20 text-white text-center py-3 px-5 rounded-xl text-sm hover:bg-white/10 transition-colors"
              >(360) 282-2218</a
            >
          </div>
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-3">Service Details</h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Residential & commercial</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Free estimates</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Licensed & insured</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Mon–Fri, 7am to 5pm</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Senior & military discount</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Ready to Transform Your Space?"
    subtext="Contact us for a free remodeling estimate. We serve across Washington."
  />
  <Footer />
</BaseLayout>
