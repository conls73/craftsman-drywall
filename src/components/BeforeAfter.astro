---
const beforeSrc = '/craftsman-drywall/images/before.jpg';
const afterSrc = '/craftsman-drywall/images/after.jpg';

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`before-after-container flex flex-col gap-4 ${className}`}>
  <!-- Toggle Controls -->
  <div class="flex justify-center">
    <div class="inline-flex bg-white/5 backdrop-blur-xl rounded-xl p-1 border border-white/10 shadow-lg">
      <button 
        id="btn-slider" 
        class="px-6 py-2 text-[10px] font-black rounded-lg bg-white text-navy shadow-md transition-all uppercase tracking-[0.2em]"
      >
        Slider
      </button>
      <button 
        id="btn-side-by-side" 
        class="px-6 py-2 text-[10px] font-black rounded-lg text-white/60 hover:text-white transition-all uppercase tracking-[0.2em]"
      >
        Side by Side
      </button>
    </div>
  </div>

  <div class="before-after-card relative overflow-hidden bg-navy rounded-3xl shadow-2xl">
    <!-- Slider View -->
    <div id="view-slider" class="relative w-full aspect-[4/5] md:aspect-square overflow-hidden group flex items-center justify-center">
      <!-- Base image (After) -->
      <img 
          src={afterSrc} 
          class="w-full h-full object-cover select-none pointer-events-none" 
          alt="After Remodel" 
      />

      <!-- Overlay image (Before) -->
      <div 
          id="before-img-container" 
          class="absolute inset-0 w-full h-full overflow-hidden select-none pointer-events-none z-10"
          style="clip-path: inset(0 50% 0 0);"
      >
          <img 
              src={beforeSrc} 
              class="w-full h-full object-cover" 
              alt="Before Remodel" 
          />
      </div>
      
      <!-- Wiping Label at the bottom -->
      <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-[45] pointer-events-none">
          <div class="relative flex items-center justify-center min-w-[140px] h-10 bg-navy/60 backdrop-blur-xl rounded-full border border-white/10 shadow-2xl overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center text-white text-[9px] font-black uppercase tracking-[0.3em] select-none">
                  After
              </div>
              <div 
                  id="before-label-wipe"
                  class="absolute inset-0 flex items-center justify-center bg-white text-navy text-[9px] font-black uppercase tracking-[0.3em] select-none transition-none"
                  style="clip-path: inset(0 50% 0 0);"
              >
                  Before
              </div>
          </div>
      </div>

      <!-- Vertical Drag Handle -->
      <div 
          id="slider-handle" 
          class="absolute top-0 bottom-0 w-1 bg-white/40 backdrop-blur-md shadow-[0_0_40px_rgba(0,0,0,0.6)] cursor-ew-resize z-40"
          style="left: 50%;"
      >
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full shadow-[0_0_50px_rgba(37,99,235,0.5)] border-4 border-blue-brand flex items-center justify-center transition-all hover:scale-110 active:scale-90">
              <svg class="w-5 h-5 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M8 9l-4 3 4 3m8-6l4 3-4 3" />
              </svg>
          </div>
      </div>

      <!-- Invisible range input -->
      <input 
          type="range" 
          id="slider-range-hidden" 
          min="0" 
          max="100" 
          value="50" 
          class="absolute inset-0 w-full h-full opacity-0 cursor-ew-resize z-50"
      />
    </div>

    <!-- Side by Side View (Uncropped) -->
    <div id="view-side-by-side" class="hidden grid-cols-2 gap-px bg-white/5 p-px">
      <div class="relative w-full aspect-[4/5] bg-navy overflow-hidden">
        <div class="absolute top-4 left-4 z-20 bg-white/90 backdrop-blur-md text-navy text-[8px] font-black px-3 py-1.5 rounded-full uppercase tracking-[0.2em]">Before</div>
        <img src={beforeSrc} class="w-full h-full object-contain" alt="Before" />
      </div>
      <div class="relative w-full aspect-[4/5] bg-navy overflow-hidden">
        <div class="absolute top-4 right-4 z-20 bg-blue-brand text-white text-[8px] font-black px-3 py-1.5 rounded-full uppercase tracking-[0.2em]">After</div>
        <img src={afterSrc} class="w-full h-full object-contain" alt="After" />
      </div>
    </div>
  </div>
</div>

<script>
  const initBeforeAfter = () => {
    const rangeInput = document.getElementById('slider-range-hidden') as HTMLInputElement;
    const beforeImgContainer = document.getElementById('before-img-container');
    const beforeLabelWipe = document.getElementById('before-label-wipe');
    const sliderHandle = document.getElementById('slider-handle');
    
    const updateSlider = (val: string) => {
      const percentage = 100 - parseInt(val);
      if (beforeImgContainer) {
        beforeImgContainer.style.clipPath = `inset(0 ${percentage}% 0 0)`;
      }
      if (beforeLabelWipe) {
        beforeLabelWipe.style.clipPath = `inset(0 ${percentage}% 0 0)`;
      }
      if (sliderHandle) {
        sliderHandle.style.left = `${val}%`;
      }
    };

    if (rangeInput) {
      rangeInput.addEventListener('input', (e) => {
        updateSlider((e.target as HTMLInputElement).value);
      });
      updateSlider(rangeInput.value);
    }

    const btnSlider = document.getElementById('btn-slider');
    const btnSideBySide = document.getElementById('btn-side-by-side');
    const viewSlider = document.getElementById('view-slider');
    const viewSideBySide = document.getElementById('view-side-by-side');

    if (btnSlider && btnSideBySide && viewSlider && viewSideBySide) {
      btnSlider.addEventListener('click', () => {
        viewSlider.classList.remove('hidden');
        viewSideBySide.classList.add('hidden');
        viewSideBySide.classList.remove('grid');

        btnSlider.classList.add('bg-white', 'text-navy');
        btnSlider.classList.remove('text-white/60', 'hover:text-white');
        
        btnSideBySide.classList.remove('bg-white', 'text-navy');
        btnSideBySide.classList.add('text-white/60', 'hover:text-white');
      });

      btnSideBySide.addEventListener('click', () => {
        viewSlider.classList.add('hidden');
        viewSideBySide.classList.remove('hidden');
        viewSideBySide.classList.add('grid');

        btnSideBySide.classList.add('bg-white', 'text-navy');
        btnSideBySide.classList.remove('text-white/60', 'hover:text-white');
        
        btnSlider.classList.remove('bg-white', 'text-navy');
        btnSlider.classList.add('text-white/60', 'hover:text-white');
      });
    }
  };

  document.addEventListener('DOMContentLoaded', initBeforeAfter);
  document.addEventListener('astro:page-load', initBeforeAfter);
</script>
