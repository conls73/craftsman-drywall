---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ComparisonHero from '../components/ComparisonHero.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

const services = [
  {
    href: '/craftsman-drywall/services/drywall-installation',
    image: '/craftsman-drywall/images/install.jpg',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    title: 'Drywall Installation',
    desc: 'Full installation for new construction and remodels. Fire-resistant and water-resistant options available for any room.',
  },
  {
    href: '/craftsman-drywall/services/drywall-repair',
    image: '/craftsman-drywall/images/repair.jpeg',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>`,
    title: 'Drywall Repair',
    desc: 'Holes, cracks, water damage, or texture matching — we patch and repair drywall seamlessly so it looks like new.',
  },
  {
    href: '/craftsman-drywall/services/remodeling',
    image: '/craftsman-drywall/images/remodel.jpg',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    title: 'Remodeling',
    desc: 'Residential and commercial remodeling done right. From basement finishes to full room transformations.',
  },
  {
    href: '/craftsman-drywall/services/painting',
    image: '/craftsman-drywall/images/paint.jpg',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>`,
    title: 'Painting',
    desc: 'Interior and exterior painting with clean, professional results. The perfect finish to every drywall project.',
  },
];
---

<BaseLayout
  title="Drywall Contractor in Olympia, WA | Craftsman Drywall LLC"
  description="Craftsman Drywall LLC offers drywall installation, repair, finishing, and texturing in Olympia, Lacey, Tumwater, and Thurston County, WA."
>
  <Header />
  <ComparisonHero />

  <!-- Services -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Our Services</h2>
        <p class="text-gray-500 text-lg max-w-2xl mx-auto">
          From new builds to patch repairs, we handle every aspect of drywall and finishing for residential and commercial clients.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map(service => (
          <a
            href={service.href}
            class="group relative bg-white border border-gray-100 rounded-2xl p-7 hover:border-blue-brand hover:shadow-xl hover:shadow-blue-brand/10 transition-all duration-300 overflow-hidden flex flex-col"
          >
            <!-- Hover Image Background -->
            <div class="absolute inset-0 z-0 opacity-0 sm:group-hover:opacity-100 transition-opacity duration-300">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover" />
              <!-- Dark overlay for text readability -->
              <div class="absolute inset-0 bg-navy/80"></div>
            </div>

            <!-- Content -->
            <div class="relative z-10 flex flex-col h-full">
              <div class="w-14 h-14 bg-blue-light rounded-xl flex items-center justify-center text-blue-brand mb-5 sm:group-hover:bg-blue-brand sm:group-hover:text-white transition-colors duration-300">
                <Fragment set:html={service.icon} />
              </div>
              <h3 class="text-lg font-bold text-gray-900 sm:group-hover:text-white transition-colors duration-300 mb-2">{service.title}</h3>
              <p class="text-gray-500 sm:group-hover:text-white/80 transition-colors duration-300 text-sm leading-relaxed">{service.desc}</p>
              <span class="mt-auto pt-4 inline-flex items-center gap-1 text-blue-brand sm:group-hover:text-blue-light text-sm font-semibold sm:group-hover:gap-2 transition-all duration-300">
                Learn more
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas (Compact Version) -->
  <section class="py-20 bg-gray-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col lg:flex-row gap-12 items-center">
        <div class="lg:w-1/3">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">Service Areas</h2>
          <p class="text-gray-500 mb-6">
            We provide professional drywall services to residential and commercial clients throughout Thurston County and surrounding areas.
          </p>
          <div class="flex flex-wrap gap-2">
            {['Olympia', 'Lacey', 'Tumwater', 'Yelm', 'DuPont', 'Steilacoom', 'Rainier', 'Tenino', 'Rochester'].map(area => (
              <span class="px-3 py-1 bg-white border border-gray-200 rounded-full text-sm text-gray-600 font-medium">
                {area}
              </span>
            ))}
          </div>
        </div>
        <div class="lg:w-2/3 grid grid-cols-2 sm:grid-cols-3 gap-4">
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-2">Thurston County</h3>
            <p class="text-sm text-gray-500">Olympia, Lacey, Tumwater, Yelm, Rainier, Tenino, Bucoda, Rochester</p>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-2">Pierce County</h3>
            <p class="text-sm text-gray-500">DuPont, Steilacoom, Roy</p>
          </div>
          <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-2">Lewis County</h3>
            <p class="text-sm text-gray-500">Centralia, Chehalis (Select Areas)</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABanner />
  <Footer />
</BaseLayout>
