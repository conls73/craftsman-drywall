---
const beforeSrc = '/craftsman-drywall/images/before.jpg';
const afterSrc = '/craftsman-drywall/images/after.jpg';
---

<div class="before-after-component w-full mx-auto bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100 p-4">
  <!-- Toggle Controls -->
  <div class="flex justify-center mb-6">
    <div class="inline-flex bg-gray-100 rounded-lg p-1">
      <button 
        id="btn-slider" 
        class="px-5 py-2 text-sm font-bold rounded-md bg-white text-navy shadow-sm transition-all"
      >
        Slider
      </button>
      <button 
        id="btn-side-by-side" 
        class="px-5 py-2 text-sm font-bold rounded-md text-gray-500 hover:text-navy transition-all"
      >
        Side by Side
      </button>
    </div>
  </div>

  <!-- Slider View -->
  <div id="view-slider" class="relative w-full rounded-lg overflow-hidden bg-gray-50 flex items-center justify-center">
    <div class="relative w-full h-full max-h-[80vh] flex items-center justify-center">
        <!-- Base image (After) -->
        <img 
            src={afterSrc} 
            class="block w-full max-h-[80vh] object-contain" 
            alt="After Remodel" 
        />
        <div class="absolute top-4 right-4 bg-navy text-white text-sm font-bold px-3 py-1 rounded shadow-md z-10">After</div>

        <!-- Overlay image (Before) -->
        <img 
            src={beforeSrc} 
            id="before-img-clip" 
            class="absolute top-0 left-1/2 -translate-x-1/2 block w-full h-full object-contain" 
            style="clip-path: polygon(0 0, 50% 0, 50% 100%, 0 100%);" 
            alt="Before Remodel" 
        />
        <!-- We use top-4 left-4 for Before, but if the image is centered with object-contain, the label might be over whitespace. 
             It's fine, it will stay in the container's corner -->
        <div class="absolute top-4 left-4 bg-white text-navy text-sm font-bold px-3 py-1 rounded shadow-md z-10 border border-gray-200">Before</div>
        
        <!-- Slider Input -->
        <div class="absolute bottom-4 left-4 right-4 z-20 flex justify-center items-center">
            <input 
                type="range" 
                id="slider-input" 
                min="0" 
                max="100" 
                value="50" 
                class="w-full max-w-2xl h-3 bg-white/70 backdrop-blur rounded-lg appearance-none cursor-pointer border border-white shadow-lg focus:outline-none focus:ring-2 focus:ring-blue-brand"
                style="
                    /* Minimal styling for range input */
                    -webkit-appearance: none;
                "
            />
            <style>
                #slider-input::-webkit-slider-thumb {
                    -webkit-appearance: none;
                    appearance: none;
                    width: 24px;
                    height: 24px;
                    background: #2563EB; /* blue-brand */
                    border-radius: 50%;
                    cursor: pointer;
                    border: 3px solid white;
                    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
                }
                #slider-input::-moz-range-thumb {
                    width: 24px;
                    height: 24px;
                    background: #2563EB;
                    border-radius: 50%;
                    cursor: pointer;
                    border: 3px solid white;
                    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
                }
            </style>
        </div>
        
        <!-- Vertical separator line -->
        <div 
            id="slider-line" 
            class="absolute top-0 bottom-0 w-1 bg-white shadow-[0_0_10px_rgba(0,0,0,0.5)] pointer-events-none z-10"
            style="left: 50%; transform: translateX(-50%);"
        ></div>
    </div>
  </div>

  <!-- Side by Side View -->
  <div id="view-side-by-side" class="hidden grid-cols-1 md:grid-cols-2 gap-4">
    <div class="relative bg-gray-50 rounded-lg overflow-hidden flex items-center justify-center border border-gray-200 p-2">
      <img src={beforeSrc} class="w-full max-h-[60vh] object-contain block rounded" alt="Before Remodel" />
      <div class="absolute top-4 left-4 bg-white text-navy text-sm font-bold px-3 py-1 rounded shadow-md z-10 border border-gray-200">Before</div>
    </div>
    <div class="relative bg-gray-50 rounded-lg overflow-hidden flex items-center justify-center border border-gray-200 p-2">
      <img src={afterSrc} class="w-full max-h-[60vh] object-contain block rounded" alt="After Remodel" />
      <div class="absolute top-4 right-4 bg-navy text-white text-sm font-bold px-3 py-1 rounded shadow-md z-10">After</div>
    </div>
  </div>
</div>

<script>
  const initBeforeAfter = () => {
    const sliderInput = document.getElementById('slider-input') as HTMLInputElement;
    const beforeImgClip = document.getElementById('before-img-clip');
    const sliderLine = document.getElementById('slider-line');
    
    if (sliderInput && beforeImgClip && sliderLine) {
      sliderInput.addEventListener('input', (e) => {
        const val = (e.target as HTMLInputElement).value;
        beforeImgClip.style.clipPath = `polygon(0 0, ${val}% 0, ${val}% 100%, 0 100%)`;
        sliderLine.style.left = `${val}%`;
      });
    }

    const btnSlider = document.getElementById('btn-slider');
    const btnSideBySide = document.getElementById('btn-side-by-side');
    const viewSlider = document.getElementById('view-slider');
    const viewSideBySide = document.getElementById('view-side-by-side');

    if (btnSlider && btnSideBySide && viewSlider && viewSideBySide) {
      btnSlider.addEventListener('click', () => {
        viewSlider.classList.remove('hidden');
        viewSideBySide.classList.add('hidden');
        viewSideBySide.classList.remove('grid');

        btnSlider.classList.add('bg-white', 'shadow-sm', 'text-navy');
        btnSlider.classList.remove('text-gray-500', 'hover:text-navy');
        
        btnSideBySide.classList.remove('bg-white', 'shadow-sm', 'text-navy');
        btnSideBySide.classList.add('text-gray-500', 'hover:text-navy');
      });

      btnSideBySide.addEventListener('click', () => {
        viewSlider.classList.add('hidden');
        viewSideBySide.classList.remove('hidden');
        viewSideBySide.classList.add('grid');

        btnSideBySide.classList.add('bg-white', 'shadow-sm', 'text-navy');
        btnSideBySide.classList.remove('text-gray-500', 'hover:text-navy');
        
        btnSlider.classList.remove('bg-white', 'shadow-sm', 'text-navy');
        btnSlider.classList.add('text-gray-500', 'hover:text-navy');
      });
    }
  };

  // Run on load and after view transitions
  document.addEventListener('DOMContentLoaded', initBeforeAfter);
  document.addEventListener('astro:page-load', initBeforeAfter);
</script>
