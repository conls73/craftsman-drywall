---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ComparisonHero from '../components/ComparisonHero.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

const services = [
  {
    href: '/craftsman-drywall/services/drywall-installation',
    image: '/craftsman-drywall/images/install.jpg',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
    title: 'Drywall Installation',
    desc: 'Full installation for new construction and remodels. Fire-resistant and water-resistant options available for any room.',
  },
  {
    href: '/craftsman-drywall/services/drywall-repair',
    image: '/craftsman-drywall/images/repair.jpeg',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>`,
    title: 'Drywall Repair',
    desc: 'Holes, cracks, water damage, or texture matching — we patch and repair drywall seamlessly so it looks like new.',
  },
  {
    href: '/craftsman-drywall/services/remodeling',
    image: '/craftsman-drywall/images/remodel.jpg',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
    title: 'Remodeling',
    desc: 'Residential and commercial remodeling done right. From basement finishes to full room transformations.',
  },
  {
    href: '/craftsman-drywall/services/painting',
    image: '/craftsman-drywall/images/paint.jpg',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>`,
    title: 'Painting',
    desc: 'Interior and exterior painting with clean, professional results. The perfect finish to every drywall project.',
  },
];

const featuredAreas = ['Olympia', 'Lacey', 'Tumwater', 'Yelm', 'DuPont', 'Steilacoom', 'Rainier', 'Tenino', 'Rochester'];
const allAreas = [
  "Olympia, WA", "West Olympia, WA", "Downtown Olympia, WA", "Eastside Olympia, WA", "Northeast Olympia, WA", "Northwest Olympia, WA", "South Capitol, Olympia, WA", "Bigelow, Olympia, WA", "Upper Eastside, Olympia, WA", "Wildwood, Olympia, WA", "Cain Road, Olympia, WA", "Carlyon-North, Olympia, WA", "Governor Stevens, Olympia, WA", "East Bay, Olympia, WA", "West Bay Drive, Olympia, WA", "Cooper Point, Olympia, WA", "Goldcrest, Olympia, WA", "Ken Lake, Olympia, WA", "Holiday Hills, Olympia, WA", "Indian Creek, Olympia, WA", "Chambers Lake Basin, Olympia, WA", "Castlewood, Olympia, WA", "Nottingham, Olympia, WA", "Evergreen State College Area, Olympia, WA", "Squaxin Park Area, Olympia, WA", "Percival Landing Area, Olympia, WA", "Capitol Campus Area, Olympia, WA", "Black Lake, Olympia, WA", "Black Lake Heights, Olympia, WA", "Mud Bay, Olympia, WA", "Delphi, Olympia, WA", "South Bay, Olympia, WA", "Boston Harbor, Olympia, WA", "Gull Harbor, Olympia, WA", "Johnson Point, Olympia, WA", "Steamboat Island, Olympia, WA", "Griffin, Olympia, WA", "Summit Lake, Olympia, WA", "Scott Lake, Olympia, WA", "Pattison Lake, Olympia, WA", "Lacey, WA", "Downtown Lacey, WA", "North Lacey, WA", "South Lacey, WA", "Hawks Prairie, Lacey, WA", "Meridian Campus, Lacey, WA", "Jubilee, Lacey, WA", "Gateway, Lacey, WA", "Pleasant Glade, Lacey, WA", "Tanglewilde, Lacey, WA", "Thompson Place, Lacey, WA", "Mushroom Corner, Lacey, WA", "Woodland District, Lacey, WA", "College Street Area, Lacey, WA", "Sleater-Kinney Road Area, Lacey, WA", "Long Lake, Lacey, WA", "Hicks Lake, Lacey, WA", "Wonderwood, Lacey, WA", "The Meadows, Lacey, WA", "Union Mills, Lacey, WA", "Beachcrest, Lacey, WA", "Nisqually, Lacey, WA", "Nisqually Indian Community, WA", "Tumwater, WA", "Downtown Tumwater, WA", "Tumwater Hill, Tumwater, WA", "South Tumwater, WA", "East Tumwater, WA", "Bush Prairie, Tumwater, WA", "Black Hills, Tumwater, WA", "Trosper, Tumwater, WA", "Israel Road, Tumwater, WA", "Capitol Boulevard, Tumwater, WA", "Tumwater Airport Area, WA", "Brewery District, Tumwater, WA", "Palermo, Tumwater, WA", "Munn Lake, Tumwater, WA", "Deschutes River Area, Tumwater, WA", "Littlerock, WA", "Maytown, WA", "Grand Mound, WA", "Rochester, WA", "Gate, WA", "Independence, WA", "Bordeaux, WA", "Vail, WA", "Rainier, WA", "Tenino, WA", "Bucoda, WA", "Yelm, WA", "Downtown Yelm, WA", "South Yelm, WA", "North Yelm, WA", "Yelm Prairie, WA", "Clearwood, Yelm, WA", "Lake Lawrence, Yelm, WA", "Bald Hills, Yelm, WA", "Lawrence Lake Area, WA", "Skookumchuck, WA", "Offutt Lake, WA"
];
---

<BaseLayout
  title="Drywall Contractor in Olympia, WA | Craftsman Drywall LLC"
  description="Craftsman Drywall LLC offers drywall installation, repair, finishing, and texturing in Olympia, Lacey, Tumwater, and Thurston County, WA."
>
  <Header />
  <ComparisonHero />

  <!-- Services -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Our Services</h2>
        <p class="text-gray-500 text-lg max-w-2xl mx-auto">
          From new builds to patch repairs, we handle every aspect of drywall and finishing for residential and commercial clients.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map(service => (
          <a
            href={service.href}
            class="group relative bg-white border border-gray-100 rounded-2xl p-7 hover:border-blue-brand hover:shadow-xl hover:shadow-blue-brand/10 transition-all duration-300 overflow-hidden flex flex-col"
          >
            <!-- Hover Image Background -->
            <div class="absolute inset-0 z-0 opacity-0 sm:group-hover:opacity-100 transition-opacity duration-300">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover" />
              <!-- Dark overlay for text readability -->
              <div class="absolute inset-0 bg-navy/80"></div>
            </div>

            <!-- Content -->
            <div class="relative z-10 flex flex-col h-full">
              <div class="w-14 h-14 bg-blue-light rounded-xl flex items-center justify-center text-blue-brand mb-5 sm:group-hover:bg-blue-brand sm:group-hover:text-white transition-colors duration-300">
                <Fragment set:html={service.icon} />
              </div>
              <h3 class="text-lg font-bold text-gray-900 sm:group-hover:text-white transition-colors duration-300 mb-2">{service.title}</h3>
              <p class="text-gray-500 sm:group-hover:text-white/80 transition-colors duration-300 text-sm leading-relaxed">{service.desc}</p>
              <span class="mt-auto pt-4 inline-flex items-center gap-1 text-blue-brand sm:group-hover:text-blue-light text-sm font-semibold sm:group-hover:gap-2 transition-all duration-300">
                Learn more
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <section class="py-24 bg-white overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-center text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Customer Reviews</h2>
        <div class="flex items-center gap-2 mb-2">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
          <span class="text-gray-500 text-sm ml-1">5.0 · Olympia, WA</span>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            name: "Josiah Price",
            date: "2 years ago",
            stars: 5,
            text: "Steve and his crew were kind, courteous and communicative. The job so far looks great and we are so glad to have had Steve complete the drywall portion of our family's ADU project. I definitely plan to call Steve again!",
          },
          {
            name: "Debra Janison",
            date: "a year ago",
            stars: 5,
            text: "Steve came promptly to assess my job and give me a bid. He is a good communicator and was able to be flexible around other contractors coming and going. He does excellent work. I'd hire him again anytime.",
          },
          {
            name: "Duane Tahran",
            date: "2 years ago",
            stars: 5,
            text: "Kevin Knight (Craftsman Drywall LLC) is easy, HONEST, RESPECTFUL and PROFESSIONAL. 5 Stars is not enough they are a PERFECT 10. THANK YOU for a job WELL DONE!!! Treated our home as if it was his own.",
          },
          {
            name: "Michael Utz",
            date: "a year ago",
            stars: 5,
            text: "I am a retired builder who has done a lot of drywall patching and finishing myself. I know how hard it is and these guys were flawless. Their integrity is in the name, Craftsman Drywall. Highly recommending them.",
          },
          {
            name: "JW Foster",
            date: "a year ago",
            stars: 5,
            text: "Steve and crew were professional, reliable, and meticulous. All the other contractors working on our house build were complimentary of their work.",
          },
          {
            name: "Josh V.",
            date: "a year ago",
            stars: 5,
            text: "Steve and his crew did an excellent job on my walls! He was very communicative and thorough. I highly recommend Craftsman Drywall!",
          },
        ].map(review => (
          <a 
            href="https://www.google.com/maps/place/Craftsman+Drywall+LLC/@47.0394865,-122.8970409,14855m/data=!3m2!1e3!4b1!4m6!3m5!1s0x549173bc2c14b065:0x8218b06f8212eff9!8m2!3d47.0394865!4d-122.8970409!16s%2Fg%2F11mthph02j?entry=ttu"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-gray-50 rounded-2xl p-6 border border-gray-100 flex flex-col gap-4 transition-all duration-300 hover:shadow-xl hover:border-blue-brand/30 hover:-translate-y-1.5 group"
          >
            <div class="flex gap-1">
              {Array.from({ length: review.stars }).map(() => (
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-gray-700 text-sm leading-relaxed flex-1 italic group-hover:text-gray-900 transition-colors">"{review.text}"</p>
            <div class="flex items-center justify-between pt-4 border-t border-gray-100">
              <div class="flex flex-col">
                <p class="text-gray-900 text-sm font-bold">{review.name}</p>
                <div class="flex items-center gap-1">
                  <p class="text-gray-400 text-xs">{review.date}</p>
                  <span class="text-blue-brand text-[10px] font-bold opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap ml-1">• READ ON GOOGLE</span>
                </div>
              </div>
              <svg class="w-5 h-5 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-blue-brand font-semibold text-sm uppercase tracking-widest mb-3">Coverage Area</p>
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-8">Proudly Serving These Communities</h2>
      <div class="flex flex-wrap justify-center gap-3 sm:gap-4 max-w-5xl mx-auto">
        {featuredAreas.map(area => (
          <div class="bg-white border border-gray-100 text-gray-700 font-semibold px-6 py-2.5 rounded-full text-sm shadow-sm flex items-center gap-2 hover:border-blue-brand hover:shadow-md hover:scale-[1.02] transition-all duration-300 cursor-default group">
            <svg class="w-4 h-4 text-red-500 group-hover:animate-bounce" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" />
            </svg>
            {area}, WA
          </div>
        ))}
      </div>

      <div class="mt-8">
        <button
          id="toggle-areas"
          class="inline-flex items-center gap-2 text-blue-brand font-bold hover:text-blue-dark transition-colors group"
        >
          <span>See More Areas</span>
          <svg class="w-5 h-5 transition-transform duration-300 group-[.active]:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div id="extended-areas" class="hidden mt-10">
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-y-3 gap-x-4 text-left border-t border-gray-200 pt-10">
            {allAreas.map(area => (
              <div class="flex items-center gap-2 text-gray-600 text-sm hover:text-blue-brand transition-colors cursor-default">
                <span class="w-1 h-1 bg-blue-brand/40 rounded-full"></span>
                {area}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const toggleBtn = document.getElementById('toggle-areas');
    const extendedAreas = document.getElementById('extended-areas');

    toggleBtn?.addEventListener('click', () => {
      const isHidden = extendedAreas?.classList.contains('hidden');
      extendedAreas?.classList.toggle('hidden');
      toggleBtn.classList.toggle('active');
      
      const btnText = toggleBtn.querySelector('span');
      if (btnText) {
        btnText.textContent = isHidden ? 'Show Fewer Areas' : 'See More Areas';
      }
    });
  </script>

  <CTABanner />
  <Footer />
</BaseLayout>
