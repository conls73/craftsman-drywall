---
interface Props {
  heading?: string;
  subtext?: string;
}

const {
  heading = "Ready to Get Started?",
  subtext = "Get a free estimate from Washington's most trusted drywall professionals."
} = Astro.props;
---

<section class="bg-blue-brand py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">{heading}</h2>
    <p class="text-white/85 text-lg mb-8">{subtext}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/craftsman-drywall/contact"
        data-estimate
        class="cta-button bg-white text-blue-brand font-bold px-8 py-4 rounded-lg text-lg hover:bg-blue-light shadow-lg"
      >
        Get a Free Estimate
      </a>
      <a
        href="tel:3602822218"
        class="cta-button border-2 border-white text-white font-bold px-8 py-4 rounded-lg text-lg hover:bg-white/10"
      >
        Call (360) 282-2218
      </a>
    </div>
  </div>
</section>
