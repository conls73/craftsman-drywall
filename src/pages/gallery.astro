---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';

// Generate the 36 photos list
const galleryItems = Array.from({ length: 36 }, (_, i) => {
  const num = i + 1;
  // Define some variety for the bento grid
  let gridClass = 'md:col-span-1 md:row-span-1';
  if (num % 7 === 1) gridClass = 'md:col-span-2 md:row-span-2';
  else if (num % 7 === 3) gridClass = 'md:col-span-1 md:row-span-2';
  else if (num % 7 === 5) gridClass = 'md:col-span-2 md:row-span-1';
  
  return {
    src: `photo-${num}.jpg`,
    class: gridClass
  };
});
---

<BaseLayout
  title="Gallery — Our Work"
  description="Browse photos of completed drywall installation, repair, and remodeling projects by Craftsman Drywall LLC in Washington."
>
  <Header />

  <!-- Page Header -->
  <section class="bg-navy py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center">
      <p class="text-blue-brand font-semibold text-sm uppercase tracking-widest mb-4">Our Work</p>
      <h1 class="text-5xl sm:text-7xl font-extrabold text-white mb-6">See the Craftsmanship</h1>
      <p class="text-white/70 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">
        A look at some of our completed projects across Washington and surrounding communities.
      </p>
    </div>
  </section>

  <!-- Gallery Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Bento Grid Gallery -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 auto-rows-[250px]">
        {galleryItems.map((item, i) => (
          <div 
            class={`group relative overflow-hidden rounded-3xl border border-gray-100 shadow-sm cursor-pointer ${item.class}`}
            onclick={`openLightbox('/craftsman-drywall/images/gallery/${item.src}')`}
          >
            <img 
              src={`/craftsman-drywall/images/gallery/${item.src}`} 
              alt={`Professional drywall project ${i + 1}`} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-navy/20 opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
              <div class="w-12 h-12 bg-white/90 rounded-full flex items-center justify-center scale-75 group-hover:scale-100 transition-transform duration-300">
                <svg class="w-6 h-6 text-navy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                </svg>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Lightbox Overlay -->
      <div id="lightbox" class="fixed inset-0 bg-navy/95 z-[100] hidden items-center justify-center p-4 md:p-12 cursor-zoom-out" onclick="closeLightbox()">
        <button class="absolute top-6 right-6 text-white/70 hover:text-white transition-colors">
          <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <img id="lightbox-img" src="" alt="Full size project photo" class="max-w-full max-h-full rounded-xl shadow-2xl object-contain" />
      </div>

      <script is:inline>
        function openLightbox(src) {
          const lightbox = document.getElementById('lightbox');
          const img = document.getElementById('lightbox-img');
          if (lightbox && img) {
            img.src = src;
            lightbox.classList.remove('hidden');
            lightbox.classList.add('flex');
            document.body.style.overflow = 'hidden';
          }
        }

        function closeLightbox() {
          const lightbox = document.getElementById('lightbox');
          if (lightbox) {
            lightbox.classList.add('hidden');
            lightbox.classList.remove('flex');
            document.body.style.overflow = 'auto';
          }
        }

        // Close on Escape key
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeLightbox();
        });
      </script>
    </div>
  </section>

  <CTABanner heading="Like What You See?" subtext="Contact us today for a free estimate on your project." />
  <Footer />
</BaseLayout>
