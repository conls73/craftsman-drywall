---
const beforeSrc = '/craftsman-drywall/images/before.jpg';
const afterSrc = '/craftsman-drywall/images/after.jpg';

interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div class={`before-after-component w-full mx-auto bg-white rounded-2xl shadow-2xl overflow-hidden border border-gray-100 ${className}`}>
  <!-- Toggle Controls -->
  <div class="flex justify-center p-4 bg-gray-50/50 border-b border-gray-100">
    <div class="inline-flex bg-gray-200/50 rounded-xl p-1 backdrop-blur-sm">
      <button 
        id="btn-slider" 
        class="px-6 py-2 text-xs font-bold rounded-lg bg-white text-navy shadow-sm transition-all uppercase tracking-wider"
      >
        Slider
      </button>
      <button 
        id="btn-side-by-side" 
        class="px-6 py-2 text-xs font-bold rounded-lg text-gray-500 hover:text-navy transition-all uppercase tracking-wider"
      >
        Side by Side
      </button>
    </div>
  </div>

  <!-- Slider View -->
  <div id="view-slider" class="relative w-full aspect-video md:aspect-[21/9] lg:aspect-[21/9] overflow-hidden bg-navy group">
    <!-- Base image (After) -->
    <img 
        src={afterSrc} 
        class="absolute inset-0 w-full h-full object-cover select-none pointer-events-none" 
        alt="After Remodel" 
    />
    <div class="absolute top-6 right-6 bg-navy/80 backdrop-blur text-white text-xs font-black px-4 py-2 rounded-full shadow-xl z-10 border border-white/10 uppercase tracking-widest">After</div>

    <!-- Overlay image (Before) -->
    <div 
      id="before-img-container" 
      class="absolute inset-0 w-full h-full overflow-hidden select-none pointer-events-none"
      style="clip-path: inset(0 50% 0 0);"
    >
      <img 
          src={beforeSrc} 
          class="absolute inset-0 w-full h-full object-cover" 
          alt="Before Remodel" 
      />
      <div class="absolute top-6 left-6 bg-white/90 backdrop-blur text-navy text-xs font-black px-4 py-2 rounded-full shadow-xl z-10 border border-gray-200 uppercase tracking-widest">Before</div>
    </div>
    
    <!-- Vertical Drag Handle -->
    <div 
        id="slider-handle" 
        class="absolute top-0 bottom-0 w-1 bg-white shadow-[0_0_15px_rgba(0,0,0,0.5)] cursor-ew-resize z-30 group-active:scale-x-150 transition-transform"
        style="left: 50%;"
    >
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-10 h-10 bg-white rounded-full shadow-2xl border-4 border-blue-brand flex items-center justify-center">
        <svg class="w-6 h-6 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M8 9l-4 3 4 3m8-6l4 3-4 3" />
        </svg>
      </div>
    </div>

    <!-- Invisible range input for mobile and backup interaction -->
    <input 
        type="range" 
        id="slider-range-hidden" 
        min="0" 
        max="100" 
        value="50" 
        class="absolute inset-0 w-full h-full opacity-0 cursor-ew-resize z-40"
    />
  </div>

  <!-- Side by Side View -->
  <div id="view-side-by-side" class="hidden grid-cols-1 md:grid-cols-2">
    <div class="relative aspect-video">
      <img src={beforeSrc} class="w-full h-full object-cover block" alt="Before Remodel" />
      <div class="absolute top-6 left-6 bg-white/90 backdrop-blur text-navy text-xs font-black px-4 py-2 rounded-full shadow-xl z-10 border border-gray-200 uppercase tracking-widest">Before</div>
    </div>
    <div class="relative aspect-video border-l border-white/20">
      <img src={afterSrc} class="w-full h-full object-cover block" alt="After Remodel" />
      <div class="absolute top-6 right-6 bg-navy/80 backdrop-blur text-white text-xs font-black px-4 py-2 rounded-full shadow-xl z-10 border border-white/10 uppercase tracking-widest">After</div>
    </div>
  </div>
</div>

<script>
  const initBeforeAfter = () => {
    const rangeInput = document.getElementById('slider-range-hidden') as HTMLInputElement;
    const beforeImgContainer = document.getElementById('before-img-container');
    const sliderHandle = document.getElementById('slider-handle');
    
    const updateSlider = (val: string) => {
      if (beforeImgContainer) {
        // We use inset(top right bottom left)
        // val=0 -> inset(0 100% 0 0) -> before is hidden
        // val=100 -> inset(0 0 0 0) -> before is full
        // So right inset is (100 - val)%
        beforeImgContainer.style.clipPath = `inset(0 ${100 - parseInt(val)}% 0 0)`;
      }
      if (sliderHandle) {
        sliderHandle.style.left = `${val}%`;
      }
    };

    if (rangeInput) {
      rangeInput.addEventListener('input', (e) => {
        updateSlider((e.target as HTMLInputElement).value);
      });
      
      // Initial set
      updateSlider(rangeInput.value);
    }

    const btnSlider = document.getElementById('btn-slider');
    const btnSideBySide = document.getElementById('btn-side-by-side');
    const viewSlider = document.getElementById('view-slider');
    const viewSideBySide = document.getElementById('view-side-by-side');

    if (btnSlider && btnSideBySide && viewSlider && viewSideBySide) {
      btnSlider.addEventListener('click', () => {
        viewSlider.classList.remove('hidden');
        viewSideBySide.classList.add('hidden');
        viewSideBySide.classList.remove('grid');

        btnSlider.classList.add('bg-white', 'shadow-sm', 'text-navy');
        btnSlider.classList.remove('text-gray-500', 'hover:text-navy');
        
        btnSideBySide.classList.remove('bg-white', 'shadow-sm', 'text-navy');
        btnSideBySide.classList.add('text-gray-500', 'hover:text-navy');
      });

      btnSideBySide.addEventListener('click', () => {
        viewSlider.classList.add('hidden');
        viewSideBySide.classList.remove('hidden');
        viewSideBySide.classList.add('grid');

        btnSideBySide.classList.add('bg-white', 'shadow-sm', 'text-navy');
        btnSideBySide.classList.remove('text-gray-500', 'hover:text-navy');
        
        btnSlider.classList.remove('bg-white', 'shadow-sm', 'text-navy');
        btnSlider.classList.add('text-gray-500', 'hover:text-navy');
      });
    }
  };

  // Run on load and after view transitions
  document.addEventListener('DOMContentLoaded', initBeforeAfter);
  document.addEventListener('astro:page-load', initBeforeAfter);
</script>
