---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';

const services = [
  {
    href: '/craftsman-drywall/services/drywall-installation',
    image: '/craftsman-drywall/images/install.jpg',
    title: 'Drywall Installation and Finishing',
    detail: 'Hand Troweled, Smooth Texture & Level 5',
    detail2: 'We will match any texture',
    desc: 'Full-service drywall installation for new construction, additions, and complete room builds. Fire-resistant and moisture-resistant options available.',
    bullets: ['New construction & additions', 'Fire-resistant drywall', 'Moisture-resistant board', 'Level 5 smooth finish available'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18 2H6L5 8h14l-1-6zM12 8v10a3 3 0 01-3 3h0a3 3 0 01-3-3V8"/>`,
  },
  {
    href: '/craftsman-drywall/services/drywall-repair',
    image: '/craftsman-drywall/images/repair.jpeg',
    title: 'Drywall Repair',
    desc: 'Expert patching and repair for holes, cracks, water damage, and texture matching. We make repairs look invisible.',
    bullets: ['Hole & crack repair', 'Water damage restoration', 'Texture matching', 'Smooth seamless results'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>`,
  },
  {
    href: '/craftsman-drywall/services/painting',
    image: '/craftsman-drywall/images/paint.jpg',
    title: 'Interior Painting',
    desc: 'Professional interior painting for walls, ceilings, trim, doors, and finished spaces. Clean prep, smooth coverage, and detailed finishing for a polished result.',
    bullets: ['Interior walls and ceilings', 'Trim, doors, and detail work', 'Smooth prep and clean finishes', 'Color updates and refreshes'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>`,
  },
  {
    href: '/craftsman-drywall/services/painting',
    image: '/craftsman-drywall/images/exterior-painting.jpg',
    title: 'Exterior Painting',
    desc: 'Durable exterior painting for homes, siding, trim, doors, and outdoor surfaces. Proper prep and quality finishes built to handle Washington weather.',
    bullets: ['Siding and exterior walls', 'Trim, doors, and accents', 'Weather-ready prep and coating', 'Clean, durable finish'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l9-9 9 9v10a1 1 0 01-1 1h-2v-7h-6v7H4a1 1 0 01-1-1V12z"/>`,
  },
];
---

<BaseLayout
  title="Drywall Services in Olympia, WA | Craftsman Drywall LLC | Craftsman Drywall LLC"
  description="Craftsman Drywall LLC offers drywall installation, repair, remodeling, and painting services in Olympia, WA. Licensed & insured. Free estimates."
>
  <Header />

  <section class="bg-navy py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center">
      <p class="text-blue-brand font-semibold text-sm uppercase tracking-widest mb-4">What We Do</p>
      <h1 class="text-5xl sm:text-7xl font-extrabold text-white mb-6">Our Services</h1>
      <p class="text-white/70 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">
        Complete drywall solutions for residential and commercial clients in Olympia and the surrounding areas.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {services.map(service => (
          <a
            href={service.href}
            class="group relative bg-white border border-gray-100 rounded-2xl p-8 hover:border-blue-brand hover:shadow-xl hover:shadow-blue-brand/10 transition-all duration-300 overflow-hidden flex flex-col"
          >
            <!-- Hover Image Background -->
            <div class="absolute inset-0 z-0 opacity-0 sm:group-hover:opacity-100 transition-opacity duration-300">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover" />
              <!-- Dark overlay for text readability -->
              <div class="absolute inset-0 bg-navy/85"></div>
            </div>

            <!-- Content -->
            <div class="relative z-10 flex items-start gap-5 flex-1">
              <div class="w-14 h-14 bg-blue-light rounded-xl flex items-center justify-center text-blue-brand flex-shrink-0 sm:group-hover:bg-blue-brand sm:group-hover:text-white transition-colors duration-300">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={service.icon} />
                </svg>
              </div>
              <div class="flex-1 flex flex-col h-full">
                <h2 class="text-xl font-bold text-gray-900 sm:group-hover:text-white transition-colors duration-300 mb-1">{service.title}</h2>
                {service.detail && <p class="text-blue-brand font-semibold text-sm mb-1 sm:group-hover:text-blue-light transition-colors">{service.detail}</p>}
                {service.detail2 && <p class="text-blue-brand font-semibold text-sm mb-3 sm:group-hover:text-blue-light transition-colors">{service.detail2}</p>}
                <p class="text-gray-500 sm:group-hover:text-white/80 transition-colors duration-300 text-sm leading-relaxed mb-4">{service.desc}</p>
                <ul class="space-y-1 mb-5">
                  {service.bullets.map(b => (
                    <li class="flex items-center gap-2 text-sm text-gray-600 sm:group-hover:text-white/90 transition-colors duration-300">
                      <svg class="w-4 h-4 text-blue-brand sm:group-hover:text-blue-light flex-shrink-0 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                      {b}
                    </li>
                  ))}
                </ul>
                <span class="mt-auto inline-flex items-center gap-1 text-blue-brand sm:group-hover:text-blue-light text-sm font-semibold sm:group-hover:gap-2 transition-all duration-300">
                  Learn more
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
  <Footer />
</BaseLayout>
