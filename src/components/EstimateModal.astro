---
---

<dialog
  id="estimate-modal"
  class="fixed inset-0 z-[100] p-4 sm:p-6 m-auto w-full max-w-2xl rounded-2xl shadow-2xl bg-white border-0 backdrop:bg-navy/60 backdrop:backdrop-blur-sm"
  aria-label="Free Estimate Form"
  aria-hidden="true"
>
  <!-- Header -->
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Request a Free Estimate</h2>
      <p class="text-gray-500 text-sm mt-1">We respond the same business day.</p>
    </div>
    <button
      id="modal-close"
      class="text-gray-400 hover:text-gray-600 transition-colors p-1 rounded-lg hover:bg-gray-100 ml-4 flex-shrink-0"
      aria-label="Close"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Form -->
  <form id="estimate-modal-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-4">
    <!-- Web3Forms Config -->
    <input type="hidden" name="access_key" value="4c92f869-dd4a-48e1-8062-948c5899c715">
    <input type="hidden" name="subject" value="New Estimate Request (Modal) from Craftsman Drywall">
    <input type="hidden" name="from_name" value="Craftsman Drywall Website">
    <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

    <!-- Success Message (Modal) -->
    <div id="modal-success" class="hidden mb-6 p-6 bg-green-50 border border-green-200 rounded-xl text-green-800">
      <div class="flex items-center gap-3">
        <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        <div>
          <p class="font-bold">Thank you!</p>
          <p class="text-sm">Request sent. We'll be in touch soon.</p>
        </div>
      </div>
    </div>

    <!-- Error Message (Modal) -->
    <div id="modal-error" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-800 text-sm">
      Something went wrong. Please try again.
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label for="modal-name" class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name *</label>
        <input
          type="text"
          id="modal-name"
          name="name"
          required
          placeholder="John Smith"
          class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition text-sm"
        />
      </div>
      <div>
        <label for="modal-phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Phone Number *</label>
        <input
          type="tel"
          id="modal-phone"
          name="phone"
          required
          placeholder="(360) 555-0100"
          class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition text-sm"
        />
      </div>
    </div>

    <div>
      <label for="modal-email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address *</label>
      <input
        type="email"
        id="modal-email"
        name="email"
        required
        placeholder="you@example.com"
        class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition text-sm"
      />
    </div>

    <!-- Address with autocomplete -->
    <div class="relative">
      <label for="modal-address" class="block text-sm font-semibold text-gray-700 mb-1.5">
        Project Address *
        <span class="text-gray-400 font-normal ml-1">(start typing to search)</span>
      </label>
      <div class="relative">
        <input
          type="text"
          id="modal-address"
          name="address"
          required
          autocomplete="off"
          placeholder="123 Main St, Washington"
          class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition text-sm"
        />
        <span id="address-spinner" class="hidden absolute right-3 top-1/2 -translate-y-1/2">
          <svg class="animate-spin w-4 h-4 text-blue-brand" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
          </svg>
        </span>
      </div>
      <!-- Suggestions dropdown -->
      <ul
        id="address-suggestions"
        class="hidden absolute z-50 w-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg overflow-hidden max-h-52 overflow-y-auto"
        role="listbox"
      ></ul>
    </div>

    <div>
      <label for="modal-service" class="block text-sm font-semibold text-gray-700 mb-1.5">Service Needed</label>
      <select
        id="modal-service"
        name="service"
        class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition text-sm"
      >
        <option value="">Select a service...</option>
        <option>Drywall Installation</option>
        <option>Drywall Repair / Patching</option>
        <option>Interior Painting</option>
        <option>Exterior Painting</option>
        <option>Other / Not Sure</option>
      </select>
    </div>

    <div>
      <label for="modal-message" class="block text-sm font-semibold text-gray-700 mb-1.5">Project Details</label>
      <textarea
        id="modal-message"
        name="message"
        rows="3"
        placeholder="Tell us about your project — size, location, timeline..."
        class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition resize-none text-sm"
      ></textarea>
    </div>

    <div class="flex flex-col sm:flex-row gap-3 pt-1">
      <button
        type="submit"
        id="modal-submit-btn"
        class="flex-1 bg-blue-brand hover:bg-blue-dark disabled:bg-gray-400 text-white font-bold py-3.5 px-6 rounded-xl transition-all duration-150 shadow-lg shadow-blue-brand/25 flex items-center justify-center gap-2"
      >
        <span id="modal-btn-text">Request Free Estimate</span>
        <svg id="modal-btn-spinner" class="hidden animate-spin w-5 h-5 text-white" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
        </svg>
      </button>
      <a
        href="tel:3602822218"
        class="flex-1 border-2 border-gray-200 text-gray-700 font-semibold py-3.5 px-6 rounded-xl text-center hover:border-blue-brand hover:text-blue-brand transition-colors duration-150 text-sm"
      >
        Or Call (360) 282-2218
      </a>
    </div>
  </form>
</dialog>

<script>
  // ── Modal open/close ──────────────────────────────────────────────
  const modal = document.getElementById('estimate-modal') as HTMLDialogElement | null;
  const closeBtn = document.getElementById('modal-close');
  const modalForm = document.getElementById('estimate-modal-form') as HTMLFormElement | null;

  function openModal() {
    if (modal?.open) return;
    modal?.showModal();
    modal?.classList.add('is-open');
    modal?.setAttribute('aria-hidden', 'false');
    document.body.classList.add('estimate-modal-open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal?.classList.remove('is-open');
    modal?.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('estimate-modal-open');
    modal?.close();
    document.body.style.overflow = '';
  }

  function isMobileEstimateModal() {
    return window.matchMedia('(max-width: 768px)').matches;
  }

  function isHomePageEstimateModal() {
    const path = window.location.pathname.replace(/\/$/, '');
    return path === '/craftsman-drywall' || path === '';
  }

  closeBtn?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    const rect = modal.getBoundingClientRect();
    const outside =
      e.clientX < rect.left || e.clientX > rect.right ||
      e.clientY < rect.top  || e.clientY > rect.bottom;
    if (outside) closeModal();
  });

  modal?.addEventListener('close', () => {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('estimate-modal-open');
    document.body.style.overflow = '';
  });

  document.addEventListener('click', (e) => {
    if (isMobileEstimateModal() && isHomePageEstimateModal() && (e.target as Element).closest('[data-estimate]')) {
      e.preventDefault();
      openModal();
    }
  });



  // ── AJAX Submission ───────────────────────────────────────────────
  const successMsg = document.getElementById('modal-success');
  const errorMsg = document.getElementById('modal-error');
  const submitBtn = document.getElementById('modal-submit-btn') as HTMLButtonElement | null;
  const btnText = document.getElementById('modal-btn-text');
  const btnSpinner = document.getElementById('modal-btn-spinner');

  modalForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');
    if (submitBtn) submitBtn.disabled = true;
    if (btnText) btnText.textContent = 'Sending...';
    btnSpinner?.classList.remove('hidden');

    const formData = new FormData(modalForm);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: json
      });
      
      if (response.ok) {
        successMsg?.classList.remove('hidden');
        modalForm.reset();
        setTimeout(closeModal, 2000);
      } else {
        errorMsg?.classList.remove('hidden');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
    } finally {
      if (submitBtn) submitBtn.disabled = false;
      if (btnText) btnText.textContent = 'Request Free Estimate';
      btnSpinner?.classList.add('hidden');
    }
  });

  // ── Address autocomplete (Nominatim / OpenStreetMap — no API key) ─
  const addressInput  = document.getElementById('modal-address') as HTMLInputElement | null;
  const suggestionBox = document.getElementById('address-suggestions') as HTMLUListElement | null;
  const spinner       = document.getElementById('address-spinner');

  let debounceTimer: ReturnType<typeof setTimeout>;

  function hideSuggestions() {
    suggestionBox?.classList.add('hidden');
    if (suggestionBox) suggestionBox.innerHTML = '';
  }

  function pickSuggestion(label: string) {
    if (addressInput) addressInput.value = label;
    hideSuggestions();
  }

  addressInput?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    const query = addressInput.value.trim();

    if (query.length < 3) { hideSuggestions(); return; }

    debounceTimer = setTimeout(async () => {
      if (!spinner || !suggestionBox) return;
      spinner.classList.remove('hidden');

      try {
        const url =
          `https://nominatim.openstreetmap.org/search` +
          `?q=${encodeURIComponent(query)}` +
          `&format=json&limit=6&countrycodes=us` +
          `&addressdetails=1`;

        const res  = await fetch(url, {
          headers: { 'Accept-Language': 'en' }
        });
        const data: Array<{ display_name: string; address?: Record<string, string> }> = await res.json();

        spinner.classList.add('hidden');
        suggestionBox.innerHTML = '';

        if (!data.length) { hideSuggestions(); return; }

        data.forEach(item => {
          let cleanName = item.display_name;
          if (item.address) {
            const addr = item.address;
            const street = [addr.house_number, addr.road].filter(Boolean).join(' ');
            const loc = addr.city || addr.town || addr.village || addr.municipality || addr.hamlet;
            const stateZip = [addr.state, addr.postcode].filter(Boolean).join(' ');
            
            const parts = [street, loc, stateZip].filter(Boolean);
            if (parts.length > 0) {
              cleanName = parts.join(', ');
            }
          }

          const li = document.createElement('li');
          li.role = 'option';
          li.className =
            'flex items-center gap-2 px-4 py-3 text-sm text-gray-700 cursor-pointer ' +
            'hover:bg-blue-light hover:text-blue-dark transition-colors border-b border-gray-50 last:border-0';

          // pin icon
          li.innerHTML =
            `<svg class="w-4 h-4 text-blue-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                 d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                 d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
             </svg>` +
            `<span class="truncate">${cleanName}</span>`;

          li.addEventListener('mousedown', (e) => {
            e.preventDefault(); // prevent input blur firing first
            pickSuggestion(cleanName);
          });

          suggestionBox.appendChild(li);
        });

        suggestionBox.classList.remove('hidden');
      } catch {
        spinner.classList.add('hidden');
      }
    }, 350);
  });

  // Keyboard nav through suggestions
  addressInput?.addEventListener('keydown', (e) => {
    const items = suggestionBox?.querySelectorAll('li');
    if (!items?.length) return;

    const active = suggestionBox?.querySelector('li.bg-blue-light') as HTMLElement | null;
    let idx = active ? Array.from(items).indexOf(active) : -1;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      active?.classList.remove('bg-blue-light', 'text-blue-dark');
      idx = (idx + 1) % items.length;
      items[idx].classList.add('bg-blue-light', 'text-blue-dark');
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      active?.classList.remove('bg-blue-light', 'text-blue-dark');
      idx = (idx - 1 + items.length) % items.length;
      items[idx].classList.add('bg-blue-light', 'text-blue-dark');
    } else if (e.key === 'Enter' && active) {
      e.preventDefault();
      pickSuggestion(active.querySelector('span')?.textContent ?? '');
    } else if (e.key === 'Escape') {
      hideSuggestions();
    }
  });

  // Hide on click outside
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('#modal-address, #address-suggestions')) {
      hideSuggestions();
    }
  });
</script>
