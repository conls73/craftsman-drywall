---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';

const services = [
  {
    href: '/craftsman-drywall/services/drywall-installation',
    title: 'Drywall Installation',
    desc: 'Full-service drywall installation for new construction, additions, and complete room builds. Fire-resistant and moisture-resistant options available.',
    bullets: ['New construction & additions', 'Fire-resistant drywall', 'Moisture-resistant board', 'Level 5 smooth finish available'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
  },
  {
    href: '/craftsman-drywall/services/drywall-repair',
    title: 'Drywall Repair',
    desc: 'Expert patching and repair for holes, cracks, water damage, and texture matching. We make repairs look invisible.',
    bullets: ['Hole & crack repair', 'Water damage restoration', 'Texture matching', 'Smooth seamless results'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/>`,
  },
  {
    href: '/craftsman-drywall/services/remodeling',
    title: 'Remodeling',
    desc: 'Residential and commercial remodeling services. From basement finishing to full gut remodels, we handle the drywall from start to finish.',
    bullets: ['Basement finishing', 'Kitchen & bathroom remodels', 'Room additions', 'Commercial tenant improvements'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    href: '/craftsman-drywall/services/painting',
    title: 'Painting',
    desc: 'Interior and exterior painting to complete your project. Professional prep, quality paint, and clean edges every time.',
    bullets: ['Interior painting', 'Exterior painting', 'Primer & prep included', 'Color consultation available'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>`,
  },
];
---

<BaseLayout
  title="Drywall Services in Olympia, WA | Craftsman Drywall LLC | Craftsman Drywall LLC"
  description="Craftsman Drywall LLC offers drywall installation, repair, remodeling, and painting services in Olympia, WA. Licensed & insured. Free estimates."
>
  <Header />

  <section class="bg-navy py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-blue-brand font-semibold text-sm uppercase tracking-widest mb-3">What We Do</p>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">Our Services</h1>
      <p class="text-white/70 text-lg max-w-xl mx-auto">
        Complete drywall solutions for residential and commercial clients in Olympia and the surrounding areas.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {services.map(service => (
          <a
            href={service.href}
            class="group bg-white border border-gray-100 rounded-2xl p-8 hover:border-blue-brand hover:shadow-xl hover:shadow-blue-brand/10 transition-all duration-200"
          >
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 bg-blue-light rounded-xl flex items-center justify-center text-blue-brand flex-shrink-0 group-hover:bg-blue-brand group-hover:text-white transition-colors duration-200">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={service.icon} />
                </svg>
              </div>
              <div class="flex-1">
                <h2 class="text-xl font-bold text-gray-900 mb-2">{service.title}</h2>
                <p class="text-gray-500 text-sm leading-relaxed mb-4">{service.desc}</p>
                <ul class="space-y-1">
                  {service.bullets.map(b => (
                    <li class="flex items-center gap-2 text-sm text-gray-600">
                      <svg class="w-4 h-4 text-blue-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                      </svg>
                      {b}
                    </li>
                  ))}
                </ul>
                <span class="mt-5 inline-flex items-center gap-1 text-blue-brand text-sm font-semibold group-hover:gap-2 transition-all">
                  Learn more
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />
  <Footer />
</BaseLayout>
