---
import EstimateModal from '../components/EstimateModal.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const siteUrl = 'https://conls73.github.io/craftsman-drywall';
const canonicalUrl = canonical ?? siteUrl + Astro.url.pathname;
const socialTitle = 'Drywall and Painting Contractor in Washington | Craftsman Drywall LLC';
const socialDescription = 'Craftsman Drywall LLC provides drywall and painting contractor services in Olympia and across Washington.';
const socialImage = `${siteUrl}/og-image-craftsman-preview.png`;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Craftsman Drywall LLC",
  "telephone": "(360) 282-2218",
  "url": siteUrl,
  "logo": `${siteUrl}/logo.svg`,
  "description": "Licensed, bonded drywall contractor serving across Washington with 30+ years of experience.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Washington",
    "addressRegion": "WA",
    "postalCode": "98506",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.0379,
    "longitude": -122.9007
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "07:00",
      "closes": "16:00"
    }
  ],
  "priceRange": "$$",
  "areaServed": ["Olympia", "Lacey", "Tumwater", "Yelm", "DuPont", "Steilacoom", "Rainier", "Tenino", "Rochester"],
  "paymentAccepted": "Cash, Check, Venmo",
  "currenciesAccepted": "USD"
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="theme-color" content="#0B1F3A" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={socialImage} />
    <meta property="og:site_name" content="Craftsman Drywall LLC" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/craftsman-drywall/favicon.png" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- LocalBusiness JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    
    <style is:global>
      /* DISABLE REVEAL ANIMATIONS */
      .reveal,
      .reveal-slow,
      .reveal-soft,
      .reveal-delay-1,
      .reveal-delay-2,
      .reveal-delay-3,
      .reveal-delay-4 {
        opacity: 1 !important;
        transform: none !important;
        visibility: visible !important;
        transition: none !important;
      }

      /* Keep simple hover animations as requested */
      .service-card,
      .review-card,
      .testimonial-card,
      .google-review-card,
      .area-card,
      .location-pill,
      .service-area-pill,
      .community-pill {
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease,
          background-color 0.3s ease;
      }

      .review-card:hover,
      .testimonial-card:hover,
      .google-review-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 18px 40px rgba(15, 40, 70, 0.14);
      }

      .location-pill:hover,
      .service-area-pill:hover,
      .community-pill:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 24px rgba(15, 40, 70, 0.12);
      }

      /* Location pin hover movement */
      .location-pill svg,
      .service-area-pill svg,
      .community-pill svg,
      .location-pill .pin-icon,
      .service-area-pill .pin-icon,
      .community-pill .pin-icon {
        transition: transform 0.3s ease;
      }

      .location-pill:hover svg,
      .service-area-pill:hover svg,
      .community-pill:hover svg,
      .location-pill:hover .pin-icon,
      .service-area-pill:hover .pin-icon,
      .community-pill:hover .pin-icon {
        transform: translateY(-2px) scale(1.08);
      }

      /* Simple button hover transitions */
      button,
      .btn,
      .cta-button,
      .floating-button,
      .estimate-button {
        transition:
          transform 0.2s ease,
          box-shadow 0.2s ease,
          background-color 0.2s ease;
      }

      button:hover,
      .btn:hover,
      .cta-button:hover,
      .floating-button:hover,
      .estimate-button:hover {
        transform: translateY(-2px);
      }

      /* Respect reduced motion */
      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          animation: none !important;
          transition: none !important;
          scroll-behavior: auto !important;
        }
      }
      /* GLOBAL MOBILE OVERRIDES */
      @media (max-width: 768px) {
        .mobile-hero-card {
          padding: 28px 24px !important;
          border-radius: 32px !important;
          background: rgba(15, 37, 70, 0.72) !important;
          backdrop-filter: blur(14px) !important;
          -webkit-backdrop-filter: blur(14px) !important;
          border: 1px solid rgba(255, 255, 255, 0.14) !important;
          box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35) !important;
        }

        .mobile-hero-title {
          font-size: clamp(38px, 10vw, 48px) !important;
          line-height: 1.08 !important;
          margin-bottom: 1rem !important;
        }

        .mobile-hero-body {
          font-size: 18px !important;
          line-height: 1.6 !important;
          margin-bottom: 1.5rem !important;
        }

        .before-after-section,
        .before-after,
        #before-after,
        .gallery-before-after,
        .before-after-wrapper {
          display: none !important;
        }

        .mobile-hero-card .cta-button {
          padding-top: 0.875rem !important;
          padding-bottom: 0.875rem !important;
          width: 100% !important;
        }
      }
    </style>
  </head>
  <body class="font-sans bg-white text-gray-800 antialiased">
    <slot />
    
    <!-- Global Floating Action Buttons -->
    <div class="global-floating-actions fixed bottom-6 right-6 sm:bottom-8 sm:right-8 z-50 flex flex-col items-center gap-3">
      <!-- Free Estimate Button -->
      <button
        data-estimate
        class="floating-button floating-estimate-button bg-blue-brand hover:bg-blue-dark text-white shadow-2xl shadow-blue-brand/30 rounded-full px-5 py-3.5 sm:px-6 sm:py-4 flex items-center justify-center gap-2.5 ring-4 ring-white/50 group min-w-[160px] sm:min-w-[200px] focus:outline-none"
        aria-label="Request a Free Estimate"
      >
        <svg class="w-5 h-5 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
        </svg>
        <span class="font-bold text-sm sm:text-base tracking-wide whitespace-nowrap">Free Estimate</span>
      </button>

      <!-- Review Us Button -->
      <a
        href="https://search.google.com/local/writereview?placeid=ChIJZbAULLxzkVQR-e8Sgm-wGII"
        target="_blank"
        rel="noopener noreferrer"
        class="floating-button floating-review-button bg-blue-brand hover:bg-blue-dark text-white shadow-2xl shadow-blue-brand/30 rounded-full px-5 py-3.5 sm:px-6 sm:py-4 flex items-center justify-center gap-2.5 ring-4 ring-white/50 group min-w-[160px] sm:min-w-[200px] focus:outline-none"
      >
        <svg class="w-5 h-5 sm:w-6 sm:h-6 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12.48 10.92v3.28h7.81c-.24 1.84-.85 3.18-1.78 4.15-1.15 1.14-2.98 2.45-6.03 2.45-4.82 0-8.67-3.89-8.67-8.8s3.85-8.8 8.67-8.8c2.62 0 4.6 1.04 6.13 2.5l2.31-2.31C19.34 1.6 16.48 0 12.48 0 5.86 0 .3 5.39.3 12s5.56 12 12.18 12c3.57 0 6.26-1.17 8.37-3.36 2.16-2.16 2.84-5.21 2.84-7.66 0-.76-.05-1.46-.14-2.06h-11.07z"/></svg>
        <span class="font-bold text-sm sm:text-base tracking-wide whitespace-nowrap">Review Us</span>
      </a>
    </div>

    <EstimateModal />
    <script>
      let mobileStickyCtaInitialized = false;

      const initMobileStickyCta = () => {
        if (mobileStickyCtaInitialized) return;

        const mediaQuery = window.matchMedia('(max-width: 768px)');
        const heroCard = document.querySelector('#master-hero-root .mobile-hero-card');
        if (!heroCard) return;

        mobileStickyCtaInitialized = true;

        const updateStickyCta = () => {
          if (!mediaQuery.matches) {
            document.body.classList.remove('show-mobile-sticky-cta');
            return;
          }

          document.body.classList.toggle('show-mobile-sticky-cta', window.scrollY > 20);
        };

        updateStickyCta();
        window.addEventListener('scroll', updateStickyCta, { passive: true });
        window.addEventListener('resize', updateStickyCta);
      };

      document.addEventListener('DOMContentLoaded', initMobileStickyCta);
      document.addEventListener('astro:page-load', initMobileStickyCta);
    </script>
  </body>
</html>
