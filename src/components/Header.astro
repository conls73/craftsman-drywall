---
const navLinks = [
  { href: '/craftsman-drywall/', label: 'Home' },
  { href: '/craftsman-drywall/services', label: 'Services' },
  { href: '/craftsman-drywall/gallery', label: 'Gallery' },
  { href: '/craftsman-drywall/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="relative z-[150] bg-navy border-b border-white/5 py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Container -->
    <div class="flex items-center justify-between gap-4 relative w-full">
      <!-- Logo (Left) -->
      <div class="flex-1 flex justify-start z-10">
        <a href="/craftsman-drywall/" class="flex items-center transition-transform hover:scale-105 duration-300">
          <img
            src="/craftsman-drywall/logo.svg"
            alt="Craftsman Drywall LLC"
            class="h-10 w-auto sm:h-12 xl:h-[100px]"
          />
        </a>
      </div>

      <!-- Centered Nav (Middle) -->
      <div class="hidden xl:flex flex-shrink-0 justify-center z-10">
        <nav class="flex items-center justify-center gap-4 bg-white/5 backdrop-blur-sm px-8 py-1.5 rounded-full border border-white/10">
          {navLinks.map(link => {
            const isHome = link.label === 'Home';
            const linkSegments = link.href.split('/').filter(Boolean);
            const linkPath = linkSegments[linkSegments.length - 1] || '';
            const currentSegments = currentPath.split('/').filter(Boolean);
            const currentLastSegment = currentSegments[currentSegments.length - 1] || '';

            let isActive;
            if (isHome) {
              isActive = (currentSegments.length === 1 && currentLastSegment === 'craftsman-drywall') || (currentSegments.length === 0);
            } else {
              isActive = currentPath.includes(`/${linkPath}`);
            }

            return (
              <a
                href={link.href}
                class={`px-8 py-2.5 rounded-full text-xs font-black transition-all duration-200 uppercase tracking-widest
                  ${isActive
                    ? 'text-white bg-blue-brand shadow-lg shadow-blue-brand/20'
                    : 'text-white/60 hover:text-white hover:bg-white/10'}`}
              >
                {link.label}
              </a>
            );
          })}
        </nav>
      </div>

      <!-- Right Side: Phone & Socials -->
      <div class="hidden xl:flex flex-1 items-center justify-end gap-8 z-10">
        <a
          href="tel:3602822218"
          class="text-white/70 text-sm font-bold hover:text-white transition-colors whitespace-nowrap"
        >
          (360) 282-2218
        </a>
        
        <!-- Social Media Links -->
        <div class="flex items-center gap-4">
          <a href="https://www.facebook.com/p/Craftsman-Drywall-LLC-61565516558153/" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:text-white transition-colors flex items-center justify-center w-8 h-8" aria-label="Facebook">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
          </a>
          <a href="https://www.google.com/maps/place/Craftsman+Drywall+LLC/data=!4m2!3m1!1s0x0:0x8218b06f8212eff9?sa=X&ved=1t:2428&ictx=111" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:text-white transition-colors flex items-center justify-center w-8 h-8" aria-label="Google Maps">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.48 10.92v3.28h7.81c-.24 1.84-.85 3.18-1.78 4.15-1.15 1.14-2.98 2.45-6.03 2.45-4.82 0-8.67-3.89-8.67-8.8s3.85-8.8 8.67-8.8c2.62 0 4.6 1.04 6.13 2.5l2.31-2.31C19.34 1.6 16.48 0 12.48 0 5.86 0 .3 5.39.3 12s5.56 12 12.18 12c3.57 0 6.26-1.17 8.37-3.36 2.16-2.16 2.84-5.21 2.84-7.66 0-.76-.05-1.46-.14-2.06h-11.07z"/></svg>
          </a>
          <a href="https://www.angi.com/companylist/us/wa/olympia/craftsman-drywall-llc-reviews-10583896.htm" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:text-white transition-colors flex items-center justify-center w-8 h-8" aria-label="Angi">
            <div class="w-[30px] h-[30px] bg-current" style="mask-image: url('/craftsman-drywall/images/angi-logo.png'); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url('/craftsman-drywall/images/angi-logo.png'); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;"></div>
          </a>
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="flex justify-end xl:hidden">
        <button
          id="menu-toggle"
          class="text-white p-2 rounded-md hover:bg-white/10 transition-colors"
          aria-label="Toggle menu"
        >
          <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>


    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden xl:hidden mt-6 pb-4 animate-in fade-in slide-in-from-top-4 duration-300">
      <nav class="flex flex-col gap-2">
        {navLinks.map(link => {
          const isHome = link.label === 'Home';
          const linkSegments = link.href.split('/').filter(Boolean);
          const linkPath = linkSegments[linkSegments.length - 1] || '';
          const currentSegments = currentPath.split('/').filter(Boolean);
          const currentLastSegment = currentSegments[currentSegments.length - 1] || '';
          
          let isActive;
          if (isHome) {
            isActive = (currentSegments.length === 1 && currentLastSegment === 'craftsman-drywall') || (currentSegments.length === 0);
          } else {
            isActive = currentPath.includes(`/${linkPath}`);
          }
            
          return (
            <a
              href={link.href}
              class={`px-4 py-3 rounded-xl text-base font-semibold transition-colors
                ${isActive
                  ? 'text-white bg-blue-brand'
                  : 'text-white/80 hover:text-white hover:bg-white/10'}`}
            >
              {link.label}
            </a>
          );
        })}
        <div class="grid grid-cols-2 gap-3 mt-4">
          <a
            href="tel:3602822218"
            class="flex items-center justify-center px-4 py-3 text-white text-sm font-bold border border-white/20 rounded-xl hover:bg-white/5 transition-colors"
          >
            Call Us
          </a>
          <a
            href="/craftsman-drywall/contact"
            data-estimate
            class="flex items-center justify-center px-4 py-3 bg-blue-brand text-white text-sm font-bold rounded-xl shadow-lg shadow-blue-brand/20"
          >
            Estimate
          </a>
        </div>

        <!-- Mobile Social Links -->
        <div class="flex items-center justify-center gap-8 mt-8 pt-8 border-t border-white/10">
          <a href="https://www.facebook.com/p/Craftsman-Drywall-LLC-61565516558153/" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:text-white transition-colors flex items-center justify-center w-10 h-10" aria-label="Facebook">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"/></svg>
          </a>
          <a href="https://www.google.com/maps/place/Craftsman+Drywall+LLC/data=!4m2!3m1!1s0x0:0x8218b06f8212eff9?sa=X&ved=1t:2428&ictx=111" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:text-white transition-colors flex items-center justify-center w-10 h-10" aria-label="Google Maps">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M12.48 10.92v3.28h7.81c-.24 1.84-.85 3.18-1.78 4.15-1.15 1.14-2.98 2.45-6.03 2.45-4.82 0-8.67-3.89-8.67-8.8s3.85-8.8 8.67-8.8c2.62 0 4.6 1.04 6.13 2.5l2.31-2.31C19.34 1.6 16.48 0 12.48 0 5.86 0 .3 5.39.3 12s5.56 12 12.18 12c3.57 0 6.26-1.17 8.37-3.36 2.16-2.16 2.84-5.21 2.84-7.66 0-.76-.05-1.46-.14-2.06h-11.07z"/></svg>
          </a>
          <a href="https://www.angi.com/companylist/us/wa/olympia/craftsman-drywall-llc-reviews-10583896.htm" target="_blank" rel="noopener noreferrer" class="text-blue-brand hover:text-white transition-colors flex items-center justify-center w-10 h-10" aria-label="Angi">
            <div class="w-[36px] h-[36px] bg-current" style="mask-image: url('/craftsman-drywall/images/angi-logo.png'); mask-size: contain; mask-repeat: no-repeat; mask-position: center; -webkit-mask-image: url('/craftsman-drywall/images/angi-logo.png'); -webkit-mask-size: contain; -webkit-mask-repeat: no-repeat; -webkit-mask-position: center;"></div>
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
