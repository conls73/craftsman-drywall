---
const navLinks = [
  { href: '/craftsman-drywall/', label: 'Home' },
  { href: '/craftsman-drywall/services', label: 'Services' },
  { href: '/craftsman-drywall/gallery', label: 'Gallery' },
  { href: '/craftsman-drywall/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="absolute top-0 left-0 w-full z-[150] bg-navy/20 backdrop-blur-md border-b border-white/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <!-- Logo -->
      <a href="/craftsman-drywall/" class="flex items-center gap-3 flex-shrink-0">
        <img
          src="/craftsman-drywall/logo.png"
          alt="Craftsman Drywall LLC"
          class="h-12 w-auto"
        />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map(link => {
          const isHome = link.label === 'Home';
          const linkPath = link.href.split('/').filter(Boolean).pop() || '';
          const currentSegments = currentPath.split('/').filter(Boolean);
          const currentLastSegment = currentSegments.pop() || '';
          
          let isActive;
          if (isHome) {
            isActive = currentSegments.length === 0 && (currentLastSegment === '' || currentLastSegment === 'craftsman-drywall');
          } else {
            isActive = currentPath.includes(`/${linkPath}`);
          }
            
          return (
            <a
              href={link.href}
              class={`px-4 py-2 rounded-md text-sm font-medium transition-colors duration-150
                ${isActive
                  ? 'text-blue-brand bg-white/10'
                  : 'text-white/80 hover:text-white hover:bg-white/10'}`}
            >
              {link.label}
            </a>
          );
        })}
      </nav>

      <!-- CTA -->
      <div class="hidden md:flex items-center gap-3">
        <a
          href="tel:3602822218"
          class="text-white/80 text-sm font-medium hover:text-white transition-colors"
        >
          (360) 282-2218
        </a>
        <a
          href="/craftsman-drywall/contact"
          data-estimate
          class="bg-blue-brand hover:bg-blue-dark text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors duration-150"
        >
          Free Estimate
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        class="md:hidden text-white p-2 rounded-md hover:bg-white/10 transition-colors"
        aria-label="Toggle menu"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <nav class="flex flex-col gap-1">
        {navLinks.map(link => {
          const isHome = link.label === 'Home';
          const linkPath = link.href.split('/').filter(Boolean).pop() || '';
          const currentSegments = currentPath.split('/').filter(Boolean);
          const currentLastSegment = currentSegments.pop() || '';
          
          let isActive;
          if (isHome) {
            isActive = currentSegments.length === 0 && (currentLastSegment === '' || currentLastSegment === 'craftsman-drywall');
          } else {
            isActive = currentPath.includes(`/${linkPath}`);
          }
            
          return (
            <a
              href={link.href}
              class={`px-4 py-3 rounded-md text-sm font-medium transition-colors
                ${isActive
                  ? 'text-blue-brand bg-white/10'
                  : 'text-white/80 hover:text-white hover:bg-white/10'}`}
            >
              {link.label}
            </a>
          );
        })}
        <a
          href="tel:3602822218"
          class="mt-2 px-4 py-3 text-white text-sm font-medium border border-white/20 rounded-md text-center"
        >
          Call (360) 282-2218
        </a>
        <a
          href="/craftsman-drywall/contact"
          data-estimate
          class="px-4 py-3 bg-blue-brand text-white text-sm font-semibold rounded-md text-center"
        >
          Free Estimate
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
