---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Contact Us — Free Estimates"
  description="Get a free estimate from Craftsman Drywall LLC. Call (360) 282-2218 or fill out our contact form. Serving Washington Mon–Fri 7am–5pm."
>
  <Header />

  <!-- Page Header -->
  <section class="bg-white py-20 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center reveal">
      <p class="text-blue-brand font-semibold text-sm uppercase tracking-widest mb-4">Get In Touch</p>
      <h1 class="text-5xl sm:text-7xl font-extrabold text-gray-900 mb-6">Let's Talk About Your Project</h1>
      <p class="text-gray-600 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed">We offer free estimates. Give us a call or send us a message and we respond the same business day.</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-20 bg-navy">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-[360px_minmax(640px,760px)] gap-12 justify-center items-start">
        <!-- Contact Info -->
        <div class="w-full space-y-8 reveal reveal-delay-1">
          <div>
            <h2 class="text-2xl font-bold text-white mb-6">Contact Information</h2>
            <div class="space-y-5">
              {[
                {
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>`,
                  label: 'Phone',
                  value: '(360) 282-2218',
                  href: 'tel:3602822218',
                },
                {
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
                  label: 'Location',
                  value: 'Washington',
                  href: null,
                },
                {
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
                  label: 'Hours',
                  value: 'Monday – Friday, 7:00am – 5:00pm',
                  href: null,
                },
              ].map(item => (
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 bg-blue-light rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <Fragment set:html={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <p class="text-xs font-semibold text-white/50 uppercase tracking-wide mb-0.5">{item.label}</p>
                    {item.href ? (
                      <a href={item.href} class="text-white font-medium hover:text-blue-brand transition-colors">{item.value}</a>
                    ) : (
                      <p class="text-white font-medium">{item.value}</p>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="w-full">
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100 form-card reveal reveal-delay-2">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Request a Free Estimate</h2>
            
            <!-- Success Message -->
            <div id="form-success" class="hidden mb-6 p-6 bg-green-50 border border-green-200 rounded-xl text-green-800 animate-in fade-in slide-in-from-top-4 duration-500">
              <div class="flex items-center gap-3">
                <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <p class="font-bold">Thank you!</p>
                  <p class="text-sm">Your request has been sent successfully. We'll get back to you soon.</p>
                </div>
              </div>
            </div>

            <!-- Error Message -->
            <div id="form-error" class="hidden mb-6 p-6 bg-red-50 border border-red-200 rounded-xl text-red-800">
              <p class="font-bold">Oops!</p>
              <p id="error-text" class="text-sm">There was a problem submitting your form. Please try again.</p>
            </div>

            <form
              name="free-estimate"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              action="/thank-you/"
              class="space-y-5"
            >
              <input type="hidden" name="form-name" value="free-estimate" />
              <input type="hidden" name="subject" value="New Free Estimate Request — Craftsman Drywall" />

              <p class="hidden">
                <label>
                  Don't fill this out if you're human:
                  <input name="bot-field" />
                </label>
              </p>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name *</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    placeholder="John Smith"
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">Phone Number *</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    placeholder="(360) 555-0100"
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition"
                  />
                </div>
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">Email Address *</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="you@example.com"
                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition"
                />
              </div>

              <!-- Address with autocomplete -->
              <div class="relative">
                <label for="contact-address" class="block text-sm font-semibold text-gray-700 mb-1.5">
                  Project Address *
                  <span class="text-gray-400 font-normal ml-1">(start typing to search)</span>
                </label>
                <div class="relative">
                  <input
                    type="text"
                    id="contact-address"
                    name="project-address"
                    required
                    autocomplete="off"
                    placeholder="123 Main St, Washington"
                    class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition"
                  />
                  <span id="contact-address-spinner" class="hidden absolute right-3 top-1/2 -translate-y-1/2">
                    <svg class="animate-spin w-4 h-4 text-blue-brand" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                    </svg>
                  </span>
                </div>
                <!-- Suggestions dropdown -->
                <ul
                  id="contact-address-suggestions"
                  class="hidden absolute z-50 w-full mt-1 bg-white border border-gray-200 rounded-xl shadow-lg overflow-hidden max-h-52 overflow-y-auto"
                  role="listbox"
                ></ul>
              </div>

              <div>
                <label for="service-needed" class="block text-sm font-semibold text-gray-700 mb-1.5">Service Needed *</label>
                <select
                  id="service-needed"
                  name="service-needed"
                  required
                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition"
                >
                  <option value="">Select a service...</option>
                  <option value="drywall-installation">Drywall Installation</option>
                  <option value="drywall-repair-patching">Drywall Repair / Patching</option>
                  <option value="interior-painting">Interior Painting</option>
                  <option value="exterior-painting">Exterior Painting</option>
                  <option value="other-not-sure">Other / Not Sure</option>
                </select>
              </div>
              <div>
                <label for="project-details" class="block text-sm font-semibold text-gray-700 mb-1.5">Project Details *</label>
                <textarea
                  id="project-details"
                  name="project-details"
                  rows="5"
                  required
                  placeholder="Tell us about the project, timeline, square footage, damage, or anything else helpful..."
                  class="w-full px-4 py-3 bg-white border border-gray-200 rounded-xl text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-brand focus:border-transparent transition resize-none"
                ></textarea>
              </div>
              <button
                type="submit"
                id="submit-btn"
                class="w-full bg-blue-brand hover:bg-blue-dark disabled:bg-gray-400 disabled:cursor-not-allowed text-white font-bold py-4 px-6 rounded-xl text-lg transition-colors duration-150 shadow-lg shadow-blue-brand/25 flex items-center justify-center gap-2"
              >
                <span id="btn-text">Send Request — It's Free</span>
                <svg id="btn-spinner" class="hidden animate-spin w-5 h-5 text-white" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
                </svg>
              </button>
              <p class="text-gray-400 text-xs text-center">We'll get back to you the same business day.</p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  // ── Address autocomplete for Contact Page (Nominatim / OpenStreetMap)
  const contactAddressInput  = document.getElementById('contact-address');
  const contactSuggestionBox = document.getElementById('contact-address-suggestions');
  const contactSpinner       = document.getElementById('contact-address-spinner');

  let contactDebounceTimer;

  function hideContactSuggestions() {
    contactSuggestionBox?.classList.add('hidden');
    if (contactSuggestionBox) contactSuggestionBox.innerHTML = '';
  }

  function pickContactSuggestion(label) {
    if (contactAddressInput) contactAddressInput.value = label;
    hideContactSuggestions();
  }

  contactAddressInput?.addEventListener('input', () => {
    clearTimeout(contactDebounceTimer);
    const query = contactAddressInput.value.trim();

    if (query.length < 3) { hideContactSuggestions(); return; }

    contactDebounceTimer = setTimeout(async () => {
      if (!contactSpinner || !contactSuggestionBox) return;
      contactSpinner.classList.remove('hidden');

      try {
        const url =
          `https://nominatim.openstreetmap.org/search` +
          `?q=${encodeURIComponent(query)}` +
          `&format=json&limit=6&countrycodes=us` +
          `&addressdetails=1`;

        const res  = await fetch(url, {
          headers: { 'Accept-Language': 'en' }
        });
        const data = await res.json();

        contactSpinner.classList.add('hidden');
        contactSuggestionBox.innerHTML = '';

        if (!data.length) { hideContactSuggestions(); return; }

        data.forEach(item => {
          let cleanName = item.display_name;
          if (item.address) {
            const addr = item.address;
            const street = [addr.house_number, addr.road].filter(Boolean).join(' ');
            const loc = addr.city || addr.town || addr.village || addr.municipality || addr.hamlet;
            const stateZip = [addr.state, addr.postcode].filter(Boolean).join(' ');
            
            const parts = [street, loc, stateZip].filter(Boolean);
            if (parts.length > 0) {
              cleanName = parts.join(', ');
            }
          }

          const li = document.createElement('li');
          li.role = 'option';
          li.className =
            'flex items-center gap-2 px-4 py-3 text-sm text-gray-700 cursor-pointer ' +
            'hover:bg-blue-light hover:text-blue-dark transition-colors border-b border-gray-50 last:border-0';

          li.innerHTML =
            `<svg class="w-4 h-4 text-blue-brand flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                 d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                 d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
             </svg>` +
            `<span class="truncate">${cleanName}</span>`;

          li.addEventListener('mousedown', (e) => {
            e.preventDefault();
            pickContactSuggestion(cleanName);
          });

          contactSuggestionBox.appendChild(li);
        });

        contactSuggestionBox.classList.remove('hidden');
      } catch {
        contactSpinner.classList.add('hidden');
      }
    }, 350);
  });

  // Keyboard nav
  contactAddressInput?.addEventListener('keydown', (e) => {
    const items = contactSuggestionBox?.querySelectorAll('li');
    if (!items?.length) return;

    const active = contactSuggestionBox?.querySelector('li.bg-blue-light');
    let idx = active ? Array.from(items).indexOf(active) : -1;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      active?.classList.remove('bg-blue-light', 'text-blue-dark');
      idx = (idx + 1) % items.length;
      items[idx].classList.add('bg-blue-light', 'text-blue-dark');
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      active?.classList.remove('bg-blue-light', 'text-blue-dark');
      idx = (idx - 1 + items.length) % items.length;
      items[idx].classList.add('bg-blue-light', 'text-blue-dark');
    } else if (e.key === 'Enter' && active) {
      e.preventDefault();
      pickContactSuggestion(active.querySelector('span')?.textContent ?? '');
    } else if (e.key === 'Escape') {
      hideContactSuggestions();
    }
  });

  // Hide on click outside
  document.addEventListener('click', (e) => {
    if (!e.target.closest('#contact-address, #contact-address-suggestions')) {
      hideContactSuggestions();
    }
  });
</script>
