---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CTABanner from '../../components/CTABanner.astro';
---

<BaseLayout
  title="Drywall Installation in Olympia, WA | Craftsman Drywall LLC"
  description="Professional drywall installation by Craftsman Drywall LLC. New construction, remodels, fire & moisture-resistant options. Serving Olympia, WA. Free estimates."
>
  <Header />

  <section class="bg-navy py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <a href="/craftsman-drywall/services" class="inline-flex items-center gap-1.5 text-white/50 text-sm hover:text-white mb-6 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          All Services
        </a>
        <p class="text-blue-brand font-semibold text-sm uppercase tracking-widest mb-3">Service</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-4">Drywall Installation</h1>
        <p class="text-white/70 text-lg">Expert installation for new construction, additions, and complete room builds across Olympia, WA.</p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2 space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Professional Drywall Installation</h2>
            <div class="space-y-4 text-gray-600 leading-relaxed">
              <p>Whether you're building new or remodeling, proper drywall installation is the foundation of every beautiful interior. Craftsman Drywall LLC brings 30+ years of installation expertise to every project in Olympia and the surrounding area.</p>
              <p>We handle everything from hanging to taping, mudding, sanding, and final texture — delivering walls that are smooth, flat, and ready for paint.</p>
            </div>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-5">What We Offer</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { 
                  title: 'Standard Installation', 
                  desc: 'Complete hanging, taping, and finishing for any room size.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4h16v6l-2 2H6l-2-2V4zm8 8v10" />`
                },
                { 
                  title: 'Fire-Resistant Drywall', 
                  desc: 'Type X fire-rated board for garages, utility rooms, and fire walls.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.99 7.99 0 0120 13a7.99 7.99 0 01-2.343 5.657z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.879 16.121A3 3 0 1012.015 11L11 14l.879 2.121z" />`
                },
                { 
                  title: 'Moisture-Resistant Board', 
                  desc: 'Green board or cement board for bathrooms, kitchens, and laundry rooms.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 21.5c-4.142 0-7.5-3.358-7.5-7.5 0-3.75 4.5-9 7.5-11.5 3 2.5 7.5 7.75 7.5 11.5 0 4.142-3.358 7.5-7.5 7.5z" />`
                },
                { 
                  title: 'Level 5 Smooth Finish', 
                  desc: 'Premium surface for high-gloss paint or glossy finishes.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-7.714 2.143L11 21l-2.143-7.714L1.143 12l7.714-2.143L11 3z" />`
                },
                { 
                  title: 'New Construction', 
                  desc: 'Full drywall packages for builders and contractors.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l9-9 9 9v9a1 1 0 01-1 1H4a1 1 0 01-1-1v-9zM12 12c-2-2-5-2-5 0s3 2 5 0m0 0c2-2 5-2 5 0s-3 2-5 0m0 0l-2 3m2-3l2 3" />`
                },
                { 
                  title: 'Room Additions', 
                  desc: 'Seamless integration with existing drywall in additions and expansions.',
                  icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />`
                },
              ].map(item => (
                <div class="bg-gray-50 rounded-xl p-6 border border-gray-100 flex gap-4">
                  <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-blue-brand" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <Fragment set:html={item.icon} />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-gray-900 mb-1">{item.title}</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-4">Our Process</h2>
            <ol class="space-y-4">
              {[
                { step: '1', title: 'Free Estimate', desc: 'We assess your project and provide a clear, written quote with no obligation.' },
                { step: '2', title: 'Material Selection', desc: "We help you choose the right drywall type for your space's requirements." },
                { step: '3', title: 'Professional Installation', desc: 'Our crew hangs, tapes, mudds, and sands to a flawless finish.' },
                { step: '4', title: 'Final Inspection', desc: 'We walk through the finished work with you to ensure your complete satisfaction.' },
              ].map(item => (
                <li class="flex gap-4">
                  <div class="w-8 h-8 bg-blue-brand text-white rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0 mt-0.5">{item.step}</div>
                  <div>
                    <h3 class="font-semibold text-gray-900">{item.title}</h3>
                    <p class="text-gray-500 text-sm leading-relaxed">{item.desc}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-5">
          <div class="bg-navy text-white rounded-2xl p-7">
            <h3 class="font-bold text-lg mb-4">Ready to Start?</h3>
            <p class="text-white/70 text-sm mb-5">Get your free estimate. We respond the same business day.</p>
            <a href="/craftsman-drywall/contact" data-estimate class="block bg-blue-brand hover:bg-blue-dark text-white font-bold text-center py-3 px-5 rounded-xl transition-colors">Get a Free Estimate</a>
            <a href="tel:3602822218" class="block mt-3 border border-white/20 text-white text-center py-3 px-5 rounded-xl text-sm hover:bg-white/10 transition-colors">(360) 282-2218</a>
          </div>
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <h3 class="font-bold text-gray-900 mb-3">Service Details</h3>
            <ul class="space-y-2 text-sm text-gray-600">
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Residential & commercial</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Free estimates</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Licensed & insured</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Mon–Fri, 7am–4pm</li>
              <li class="flex gap-2"><span class="text-blue-brand font-bold">✓</span> Senior & military discount</li>
            </ul>
          </div>
          <div class="bg-blue-light rounded-2xl p-6 border border-blue-brand/20">
            <p class="text-blue-dark font-semibold mb-1">Areas Served</p>
            <p class="text-gray-600 text-sm">Olympia · Lacey · Tumwater · Yelm · DuPont · Steilacoom · Rainier · Tenino · Rochester</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABanner heading="Need Drywall Installed?" subtext="Call us or request a free estimate online. We serve all of Olympia, WA." />
  <Footer />
</BaseLayout>
